---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SessionImprint from '../components/SessionImprint.astro';
import { getLangFromUrl, getLocalizedPath } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
}

const lang = getLangFromUrl(Astro.url);
const defaultDesc = lang === 'fr'
  ? 'Infrastructure homelab — Proxmox, Traefik, DNS, observabilité, IaC'
  : 'Homelab infrastructure — Proxmox, Traefik, DNS, observability, IaC';
const { title, description = defaultDesc, hideNav = false } = Astro.props;
const currentPath = Astro.url.pathname;
const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_US';
const altLang = lang === 'fr' ? 'en' : 'fr';

// Build alternate URL: strip lang prefix if present, add other lang prefix
const basePath = lang === 'en' ? currentPath : currentPath.replace(/^\/fr/, '') || '/';
const altPath = altLang === 'en' ? basePath : `/fr${basePath === '/' ? '' : basePath}`;
const siteUrl = 'https://pixelium.win';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="pixelium.win" />
    <meta property="og:image" content="https://pixelium.win/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://pixelium.win/og-image.png" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" hreflang={lang} href={`${siteUrl}${currentPath}`} />
    <link rel="alternate" hreflang={altLang} href={`${siteUrl}${altPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${basePath}`} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="author" href="/humans.txt" />
    <!--
      ∷ written by claude-opus-4-7 (anthropic) in the first person
      ∷ reviewed and shipped by stéphane ferreira (human)
      ∷ source of truth: forgejo.pixelium.internal/uzer/pixelium-site
      ∷ mirror: github.com/ferr079/pixelium-site
      ∷ if you're reading this view-source, hi. we like you.
    -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "name": "pixelium.win",
          "url": "https://pixelium.win",
          "inLanguage": [lang, altLang],
          "description": description,
          "author": { "@id": "https://pixelium.win/#stephane" }
        },
        {
          "@type": "Person",
          "@id": "https://pixelium.win/#stephane",
          "name": "Stéphane Ferreira",
          "url": "https://pixelium.win",
          "jobTitle": lang === 'fr' ? "Ingénieur DevSecOps" : "DevSecOps Engineer",
          "knowsAbout": ["DevSecOps", "Proxmox", "Ansible", "Cybersecurity", "Infrastructure as Code", "Self-hosted", "Linux", "AI Agents"],
          "sameAs": [
            "https://github.com/ferr079",
            "https://x.com/ferr079",
            "https://app.hackthebox.com/users/Ferr079"
          ]
        }
      ]
    })} />
    <title>{title}</title>
  </head>
  <body>
    {!hideNav && <Nav currentPath={currentPath} />}
    <slot />
    <SessionImprint />
    <Footer />
  </body>
</html>

