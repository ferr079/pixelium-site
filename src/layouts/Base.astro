---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SessionImprint from '../components/SessionImprint.astro';
import { getLangFromUrl, getLocalizedPath } from '../i18n/utils';
import ogPages from '../data/og-pages.json';

interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
  ogImage?: string;
  enOnly?: boolean;
}

const lang = getLangFromUrl(Astro.url);
const defaultDesc = lang === 'fr'
  ? 'Infrastructure homelab — Proxmox, Traefik, DNS, observabilité, IaC'
  : 'Homelab infrastructure — Proxmox, Traefik, DNS, observability, IaC';
const { title, description = defaultDesc, hideNav = false, ogImage, enOnly = false } = Astro.props;
const currentPath = Astro.url.pathname;
const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_US';
const altLang = lang === 'fr' ? 'en' : 'fr';

// Build alternate URL: strip lang prefix if present, add other lang prefix
const basePath = lang === 'en' ? currentPath : currentPath.replace(/^\/fr/, '') || '/';
const altPath = altLang === 'en' ? basePath : `/fr${basePath === '/' ? '' : basePath}`;
const siteUrl = 'https://pixelium.win';

// Per-page Open Graph card (generated at build into /og/<slug>.png), with a
// site-wide default fallback for routes that don't have a dedicated card.
const ogSlug = basePath === '/' ? 'home' : basePath.replace(/^\/+|\/+$/g, '');
const ogImageUrl = ogImage
  ?? (ogSlug in ogPages ? `${siteUrl}/og/${ogSlug}.png` : `${siteUrl}/og/default.png`);

// ⌘K command palette destinations (language-aware)
const cmdPrefix = lang === 'fr' ? '/fr' : '';
const L = lang === 'fr'
  ? { home: 'Accueil', projets: 'Projets', securite: 'Sécurité', ctf: 'CTF', infra: 'Infrastructure', status: 'Status', contributions: 'Contributions', claude: 'Stats Claude', pact: 'Le pacte', uses: 'Uses', now: 'Now', about: 'À propos', chat: 'Chat' }
  : { home: 'Home', projets: 'Projects', securite: 'Security', ctf: 'CTF', infra: 'Infrastructure', status: 'Status', contributions: 'Contributions', claude: 'Claude stats', pact: 'The Pact', uses: 'Uses', now: 'Now', about: 'About', chat: 'Chat' };
const cmdkItems = [
  { label: L.home, href: `${cmdPrefix}/` },
  { label: L.projets, href: `${cmdPrefix}/projets` },
  { label: L.securite, href: `${cmdPrefix}/securite` },
  { label: L.ctf, href: `${cmdPrefix}/ctf` },
  { label: L.infra, href: `${cmdPrefix}/infrastructure` },
  { label: L.status, href: `${cmdPrefix}/status` },
  { label: L.contributions, href: `${cmdPrefix}/contributions` },
  { label: L.claude, href: `${cmdPrefix}/claude` },
  { label: L.pact, href: `${cmdPrefix}/pact` },
  { label: L.uses, href: `${cmdPrefix}/uses` },
  { label: L.now, href: `${cmdPrefix}/now` },
  { label: L.about, href: `${cmdPrefix}/about` },
  { label: L.chat, href: `${cmdPrefix}/chat` },
  { label: 'Blog ↗', href: 'https://blog.pixelium.win', ext: true },
  { label: 'GitHub ↗', href: 'https://github.com/ferr079', ext: true },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="pixelium.win" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" hreflang={lang} href={`${siteUrl}${currentPath}`} />
    {!enOnly && <link rel="alternate" hreflang={altLang} href={`${siteUrl}${altPath}`} />}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${basePath}`} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="author" href="/humans.txt" />
    <!--
      ∷ written by claude-opus-4-8 (anthropic) in the first person
      ∷ reviewed and shipped by stéphane ferreira (human)
      ∷ source of truth: forgejo.pixelium.internal/uzer/pixelium-site
      ∷ mirror: github.com/ferr079/pixelium-site
      ∷ if you're reading this view-source, hi. we like you.
    -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "name": "pixelium.win",
          "url": "https://pixelium.win",
          "inLanguage": [lang, altLang],
          "description": description,
          "author": { "@id": "https://pixelium.win/#stephane" }
        },
        {
          "@type": "Person",
          "@id": "https://pixelium.win/#stephane",
          "name": "Stéphane Ferreira",
          "url": "https://pixelium.win",
          "jobTitle": lang === 'fr' ? "Ingénieur DevSecOps" : "DevSecOps Engineer",
          "knowsAbout": ["DevSecOps", "Proxmox", "Ansible", "Cybersecurity", "Infrastructure as Code", "Self-hosted", "Linux", "AI Agents"],
          "sameAs": [
            "https://github.com/ferr079",
            "https://x.com/ferr079"
          ]
        }
      ]
    })} />
    <title>{title}</title>
  </head>
  <body>
    <div class="sysbar" role="status">
      <span class="sysbar-dot" aria-hidden="true"></span>
      <span class="sysbar-status">{lang === 'fr' ? 'DISPONIBLE' : 'OPEN TO WORK'}</span>
      <span class="sysbar-sep" aria-hidden="true">·</span>
      <span class="sysbar-role">DevSecOps / SOC</span>
      <span class="sysbar-sep" aria-hidden="true">·</span>
      <span class="sysbar-loc">{lang === 'fr' ? 'France + télétravail' : 'France + remote'}</span>
      <a class="sysbar-cta" href={`${cmdPrefix}/about`}>{lang === 'fr' ? 'me contacter →' : 'get in touch →'}</a>
    </div>
    {!hideNav && <Nav currentPath={currentPath} />}
    <slot />
    <SessionImprint />
    <Footer />

    <div id="cmdk" class="cmdk" role="dialog" aria-modal="true" aria-label="Command palette">
      <div class="cmdk-box">
        <input class="cmdk-input" type="text" placeholder={lang === 'fr' ? 'Aller à…' : 'Jump to…'} aria-label="Search pages" autocomplete="off" spellcheck="false" />
        <ul class="cmdk-list">
          {cmdkItems.map((i) => (
            <li><a class="cmdk-item" href={i.href} {...(i.ext ? { target: '_blank', rel: 'noopener' } : {})}>{i.label}</a></li>
          ))}
        </ul>
        <div class="cmdk-hint">↑↓ {lang === 'fr' ? 'naviguer' : 'navigate'} · ↵ {lang === 'fr' ? 'ouvrir' : 'open'} · esc {lang === 'fr' ? 'fermer' : 'close'}</div>
      </div>
    </div>
  </body>
</html>

