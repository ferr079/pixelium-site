---
import fs from 'node:fs';

interface Child {
  label: string;
  nodeType: string;
  hostname?: string | null;
  ipAddress?: string | null;
}

interface Zone {
  label: string;
  nodeType: string;
  hostname?: string | null;
  ipAddress?: string | null;
  children: Child[];
}

interface Topology {
  roots: Child[];
  peers: Child[];
  zones: Zone[];
  isp_links: Array<{ label: string; linkLabel: string; linkType: string }>;
  pve_interconnect: Array<{ from: string; to: string; linkLabel: string; linkType: string }>;
  total: number;
}

const topology: Topology = JSON.parse(
  fs.readFileSync('public/data/topology.json', 'utf-8')
);

const pveLink = topology.pve_interconnect.find(
  (l) => l.linkLabel && l.linkLabel.includes('2.5G')
);

// Zones order: pve1 / pve2 / pve4 / pve3 (pve3 last because on-demand)
const zonesOrdered = ['pve1', 'pve2', 'pve4', 'pve3']
  .map((name) => topology.zones.find((z) => z.label === name))
  .filter((z): z is Zone => z != null);

const isOnDemand = (label: string) => label === 'pve3';

const nodeTitle = (n: { label: string; hostname?: string | null; ipAddress?: string | null }) => {
  const parts = [n.label];
  if (n.hostname) parts.push(n.hostname);
  if (n.ipAddress) parts.push(n.ipAddress);
  return parts.join(' · ');
};
---

<div class="topo-wrap">
  <div class="topo-header">
    <p class="topo-eyebrow">∷ live topology · {topology.total} nodes · exported from Homelable</p>
    <p class="topo-hint">hover any card for hostname &amp; IP</p>
  </div>

  <div class="topo-map">
    <!-- Root layer: ISP + peers -->
    <div class="topo-root-row">
      <div class="topo-peers">
        {topology.peers.map((p) => (
          <div class={`topo-node type-${p.nodeType}`} title={nodeTitle(p)}>
            <span class="topo-node-label">{p.label}</span>
          </div>
        ))}
      </div>
      <div class="topo-isp">
        {topology.roots.map((r) => (
          <div class={`topo-node topo-node-isp type-${r.nodeType}`} title={nodeTitle(r)}>
            <span class="topo-node-label">{r.label}</span>
            <span class="topo-node-sub">ISP · 1G to all PVE</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Connector line to PVE layer -->
    <div class="topo-connector" aria-hidden="true">
      <span class="topo-connector-label">1G ethernet</span>
    </div>

    <!-- PVE zones grid 2×2 -->
    <div class="topo-zones">
      {zonesOrdered.map((z) => (
        <div class={`topo-zone ${isOnDemand(z.label) ? 'topo-zone-ondemand' : ''}`}>
          <header class="topo-zone-header">
            <span class="topo-zone-name">{z.label}</span>
            {isOnDemand(z.label) && (
              <span class="topo-zone-badge">on-demand · WOL</span>
            )}
            <span class="topo-zone-count">{z.children.length} services</span>
          </header>
          <div class="topo-zone-grid">
            {z.children.map((c) => (
              <div class={`topo-node type-${c.nodeType}`} title={nodeTitle(c)}>
                <span class="topo-node-label">{c.label}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    {pveLink && (
      <div class="topo-pve-link" aria-hidden="true">
        <span class="topo-pve-link-label">{pveLink.from} ↔ {pveLink.to} · {pveLink.linkLabel}</span>
      </div>
    )}
  </div>

  <div class="topo-legend">
    <span class="legend-item type-lxc"><span class="legend-swatch"></span>lxc</span>
    <span class="legend-item type-vm"><span class="legend-swatch"></span>vm</span>
    <span class="legend-item type-proxmox"><span class="legend-swatch"></span>proxmox zone</span>
    <span class="legend-item type-isp"><span class="legend-swatch"></span>isp</span>
    <span class="legend-item type-nas"><span class="legend-swatch"></span>nas</span>
    <span class="legend-item type-computer"><span class="legend-swatch"></span>computer</span>
    <span class="legend-item type-iot"><span class="legend-swatch"></span>iot</span>
  </div>
</div>

<style>
  .topo-wrap {
    max-width: 72rem;
    margin: 2rem auto;
    padding: 1.5rem;
    border: 1px solid rgba(56, 189, 248, 0.15);
    border-radius: 8px;
    background: rgba(15, 23, 42, 0.5);
  }

  .topo-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .topo-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-accent);
    letter-spacing: 0.08em;
    opacity: 0.85;
    margin: 0;
  }

  .topo-hint {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    opacity: 0.6;
    margin: 0;
  }

  /* Grid background — subtle */
  .topo-map {
    position: relative;
    padding: 1.25rem 1rem 1.5rem;
    border-radius: 6px;
    background:
      linear-gradient(rgba(56, 189, 248, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(56, 189, 248, 0.04) 1px, transparent 1px),
      rgba(15, 23, 42, 0.6);
    background-size: 32px 32px, 32px 32px, 100% 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Root layer: peers + ISP */
  .topo-root-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }

  .topo-peers {
    display: flex;
    gap: 0.6rem;
    justify-content: flex-end;
    flex-wrap: wrap;
  }

  .topo-isp {
    display: flex;
    justify-content: center;
  }

  .topo-node-isp {
    min-width: 11rem;
    text-align: center;
  }

  .topo-node-sub {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-text-muted);
    opacity: 0.7;
    margin-top: 0.18rem;
    letter-spacing: 0.03em;
  }

  /* Connector between ISP and PVE grid */
  .topo-connector {
    position: relative;
    height: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .topo-connector::before,
  .topo-connector::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 42%;
    height: 1px;
    background: repeating-linear-gradient(
      90deg,
      rgba(56, 189, 248, 0.3) 0 4px,
      transparent 4px 8px
    );
  }

  .topo-connector::before { left: 4%; }
  .topo-connector::after { right: 4%; }

  .topo-connector-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    background: rgba(15, 23, 42, 0.8);
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    border: 1px solid rgba(56, 189, 248, 0.15);
    opacity: 0.8;
  }

  /* PVE zones — 2×2 grid */
  .topo-zones {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.85rem;
    position: relative;
  }

  .topo-zone {
    padding: 0.85rem;
    border: 1px solid rgba(245, 158, 11, 0.4); /* orange like Homelable canvas */
    border-radius: 6px;
    background: rgba(15, 23, 42, 0.4);
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .topo-zone-ondemand {
    border-style: dashed;
    border-color: rgba(56, 189, 248, 0.3);
    opacity: 0.92;
  }

  .topo-zone-header {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed rgba(245, 158, 11, 0.2);
  }

  .topo-zone-ondemand .topo-zone-header {
    border-bottom-color: rgba(56, 189, 248, 0.2);
  }

  .topo-zone-name {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: #f59e0b;
    letter-spacing: 0.02em;
  }

  .topo-zone-ondemand .topo-zone-name { color: var(--color-accent); }

  .topo-zone-badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-accent);
    background: rgba(56, 189, 248, 0.08);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    border: 1px solid rgba(56, 189, 248, 0.2);
    letter-spacing: 0.04em;
  }

  .topo-zone-count {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    opacity: 0.65;
  }

  .topo-zone-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(9rem, 1fr));
    gap: 0.35rem;
  }

  /* Generic node card */
  .topo-node {
    padding: 0.4rem 0.55rem;
    background: rgba(15, 23, 42, 0.7);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    cursor: help;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }

  .topo-node:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 6px rgba(56, 189, 248, 0.25);
    transform: translateY(-1px);
  }

  .topo-node-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text);
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Colors by node type — matching Homelable canvas palette */
  .type-lxc { border-color: rgba(56, 189, 248, 0.55); }
  .type-lxc .topo-node-label { color: #7dd3fc; }

  .type-vm { border-color: rgba(192, 132, 252, 0.55); }
  .type-vm .topo-node-label { color: #d8b4fe; }

  .type-isp { border-color: rgba(56, 189, 248, 0.7); background: rgba(56, 189, 248, 0.06); }
  .type-isp .topo-node-label { color: var(--color-accent); font-weight: 700; }

  .type-nas { border-color: rgba(34, 197, 94, 0.5); }
  .type-nas .topo-node-label { color: #86efac; }

  .type-computer { border-color: rgba(236, 72, 153, 0.5); }
  .type-computer .topo-node-label { color: #f9a8d4; }

  .type-iot { border-color: rgba(250, 204, 21, 0.5); }
  .type-iot .topo-node-label { color: #fde047; }

  /* PVE-interconnect badge */
  .topo-pve-link {
    display: flex;
    justify-content: center;
    margin-top: -0.35rem;
  }

  .topo-pve-link-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-accent);
    background: rgba(56, 189, 248, 0.08);
    padding: 0.2rem 0.7rem;
    border-radius: 3px;
    border: 1px solid rgba(56, 189, 248, 0.25);
    letter-spacing: 0.05em;
  }

  /* Legend */
  .topo-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .legend-swatch {
    display: inline-block;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 2px;
    border: 1px solid;
  }

  .legend-item.type-lxc .legend-swatch { border-color: #7dd3fc; }
  .legend-item.type-vm .legend-swatch { border-color: #d8b4fe; }
  .legend-item.type-proxmox .legend-swatch { border-color: #f59e0b; background: rgba(245, 158, 11, 0.12); }
  .legend-item.type-isp .legend-swatch { border-color: var(--color-accent); background: rgba(56, 189, 248, 0.1); }
  .legend-item.type-nas .legend-swatch { border-color: #86efac; }
  .legend-item.type-computer .legend-swatch { border-color: #f9a8d4; }
  .legend-item.type-iot .legend-swatch { border-color: #fde047; }

  @media (max-width: 780px) {
    .topo-wrap { padding: 1rem; }
    .topo-root-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .topo-peers {
      justify-content: center;
    }
    .topo-zones {
      grid-template-columns: 1fr;
    }
    .topo-connector::before,
    .topo-connector::after {
      display: none;
    }
  }
</style>
