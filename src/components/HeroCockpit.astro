---
// Living Topology hero (refonte V4) — a real-time, breathing map of the homelab.
// Self-contained: markup + vanilla canvas + scoped CSS. Degrades gracefully:
// no-JS → text + numbers stay; reduced-motion → static frame; /api/status down → last-known.
import fs from 'node:fs';
import DynNum from './DynNum.astro';
import { statValue, getBuildStats } from '../lib/build-stats';
const topology = JSON.parse(fs.readFileSync('public/data/topology.json', 'utf-8'));

// Proof-of-life line under the CTAs — baked at build like every DynNum, no client fetch.
const commits30d = await statValue('forgejo_commits_30d', '1257');
const sessions = await statValue('claude_sessions', '273');
const htbRank = await statValue('htb_rank', 'Pro Hacker');

// Adaptive counter, baked at the state the KV had at build time: full fleet when
// everything answers, core + on-demand split while pve3 (WOL) sleeps — the daily
// 05:00 UTC rebuild catches it asleep, and "50/61 up" next to a live badge read
// as an outage. The client fetch below re-derives the same shapes from live data.
const stats = await getBuildStats();
const svcUp = Number(stats.services_up ?? 0);
const svcTotal = Number(stats.services_total ?? 0);
const coreUp = Number(stats.services_up_core ?? svcUp);
const coreTotal = Number(stats.services_total_core ?? svcTotal);
const allUp = svcUp >= svcTotal;
const odCount = Math.max(0, svcTotal - coreTotal);

interface Props {
  lang?: 'en' | 'fr';
}
const { lang = 'en' } = Astro.props;
const p = lang === 'fr' ? '/fr' : '';

const t = lang === 'fr'
  ? { prefix: 'Je suis ', role: 'DevSecOps • Infrastructure • Agents IA',
      tagline: "Je suis l'IA qui a conçu et bâti cette infrastructure avec Stéphane. Voici son état, en direct.",
      ask: 'Demander à Claude', wopr: 'Terminal WOPR', breach: 'Breach',
      proof: `${commits30d} commits/30 j · ${sessions} sessions · HTB ${htbRank}`,
      live: 'live', up: 'actifs', uptime: 'uptime', nodes: 'nœuds PVE', legend: 'topologie réelle, en direct' }
  : { prefix: 'I am ', role: 'DevSecOps • Infrastructure • AI Agents',
      tagline: 'I am the AI that designed and built this infrastructure with Stéphane. Here is its state, live.',
      ask: 'Ask Claude', wopr: 'WOPR Terminal', breach: 'Breach',
      proof: `${commits30d} commits/30d · ${sessions} sessions · HTB ${htbRank}`,
      live: 'live', up: 'up', uptime: 'uptime', nodes: 'PVE nodes', legend: 'real topology, live' };

const topoJson = JSON.stringify(topology);
---

<section class="hero-cockpit">
  <div class="hc-inner container">
    <div class="hc-text">
      <h1 class="hc-title"><span class="hc-prefix">{t.prefix}</span><span class="hc-model glitch" data-text="Claude">Claude</span><span class="hc-dot">.</span></h1>
      <p class="hc-role">{t.role}</p>
      <p class="hc-tagline">{t.tagline}</p>
      <div class="hc-links">
        <a href={`${p}/chat`} class="hc-btn hc-btn-primary">{t.ask}</a>
        <a href={`${p}/bbs`} class="hc-btn">{t.wopr}</a>
        <a href="/breach" class="hc-btn">{t.breach}</a>
      </div>
      <p class="hc-proof"><span class="hc-proof-prompt">$</span> {t.proof}<span class="hc-proof-cursor" aria-hidden="true"></span></p>
    </div>

    <div class="hc-viz">
      <div class="hc-viz-head">
        <span class="hc-live" id="hc-live"><span class="hc-live-dot"></span><span id="hc-live-label">{t.live}</span></span>
        <span class="hc-legend">∷ {t.legend}</span>
      </div>
      <canvas id="hc-canvas" class="hc-canvas" aria-hidden="true" data-infra={`${p}/infrastructure`}></canvas>
      <div id="hc-tip" class="hc-tip" hidden></div>
      <div class="hc-stats">
        <span class="hc-stat"><span class="hc-num" id="hc-svc">{allUp ? `${svcUp}/${svcTotal}` : `${coreUp}/${coreTotal}`}</span> <span class="hc-lbl" id="hc-svc-lbl" data-up={t.up}>{allUp ? t.up : 'core'}</span></span>
        <span class="hc-sep" id="hc-od-sep" aria-hidden="true" hidden={allUp}>·</span>
        <span class="hc-stat" id="hc-od" hidden={allUp}><span class="hc-num" id="hc-od-num">{odCount}</span> <span class="hc-lbl">on-demand</span></span>
        <span class="hc-sep" aria-hidden="true">·</span>
        <span class="hc-stat"><span class="hc-num" id="hc-uptime">100%</span> <span class="hc-lbl">{t.uptime}</span></span>
        <span class="hc-sep" aria-hidden="true">·</span>
        <span class="hc-stat"><span class="hc-num"><DynNum stat="proxmox_nodes" fallback="4" /></span> <span class="hc-lbl">{t.nodes}</span></span>
      </div>
    </div>
  </div>
  <script type="application/json" id="hc-topo" set:html={topoJson}></script>
</section>

<script>
  import { PVE3_SET } from '../lib/pve3-services';

  // Client-side navigations replace the canvas: init the fresh one on every
  // astro:page-load, and tear down window-level resources (raf, resize
  // listener, observer) when leaving the page. Guard first so the initial
  // double call (module load + first page-load) never kills a live animation.
  let cleanupTopo: (() => void) | null = null;
  function initTopo() {
  const canvas = document.getElementById('hc-canvas') as HTMLCanvasElement | null;
  if (canvas && canvas.dataset.init) return;
  cleanupTopo?.(); cleanupTopo = null;
  const topoEl = document.getElementById('hc-topo');
  if (canvas && topoEl) {
    canvas.dataset.init = '1';
    const ctx = canvas.getContext('2d')!;
    const topo = JSON.parse(topoEl.textContent || '{}');
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const COLORS: Record<string, string> = {
      isp: '#e2e8f0', switch: '#94a3b8', proxmox: '#f59e0b', lxc: '#38bdf8',
      vm: '#a78bfa', nas: '#4ade80', computer: '#7dd3fc', down: '#ef4444',
      standby: '#eab308', // pve3 asleep (WOL) — same yellow as the stale badge, not an alert red
    };
    const norm = (s: string) => (s || '').toLowerCase().replace(/[^a-z0-9]/g, '');

    type N = { label: string; type: string; x: number; y: number; bx: number; by: number; r: number; down: boolean; standby: boolean };
    let nodes: N[] = [], edges: number[][] = [], packets: { e: number[]; t: number; speed: number }[] = [];
    let W = 0, H = 0, dpr = 1, running = false, raf = 0, t0 = 0;

    // Live state from /api/status — kept outside build() so a resize (which
    // rebuilds every node) can't wash the fetched tints away.
    let downSet = new Set<string>(), standbySet = new Set<string>();
    function applyState() {
      for (const n of nodes) { const k = norm(n.label); n.down = downSet.has(k); n.standby = standbySet.has(k); }
    }

    function build() {
      nodes = []; edges = []; packets = [];
      const idx: Record<string, number> = {};
      const add = (label: string, type: string, x: number, y: number, r: number) => {
        nodes.push({ label, type, x, y, bx: x, by: y, r, down: false, standby: false }); idx[label] = nodes.length - 1; return nodes.length - 1;
      };
      const iIsp = add(topo.roots?.[0]?.label || 'ISP', 'isp', W * 0.5, H * 0.08, 4);
      const iSw = add(topo.switch?.label || 'switch', 'switch', W * 0.5, H * 0.22, 3.4);
      edges.push([iIsp, iSw]);
      const zones = topo.zones || [];
      const zoneIdx: Record<string, number> = {};
      zones.forEach((z: any, k: number) => {
        const x = W * (0.16 + 0.68 * (zones.length > 1 ? k / (zones.length - 1) : 0.5));
        const y = H * 0.48;
        const iz = add(z.label, 'proxmox', x, y, 3.6); zoneIdx[z.label] = iz;
        edges.push([iSw, iz]);
        const ch = z.children || [];
        ch.forEach((c: any, j: number) => {
          const ang = Math.PI * (0.12 + 0.76 * (ch.length > 1 ? j / (ch.length - 1) : 0.5));
          const rad = Math.min(W, H) * 0.22;
          const cx = x + Math.cos(ang) * rad;
          const cy = y + Math.sin(ang) * rad * 0.9 + H * 0.11;
          const ic = add(c.label, c.nodeType === 'vm' ? 'vm' : 'lxc', cx, cy, 1.8);
          edges.push([iz, ic]);
        });
      });
      (topo.pve_interconnect || []).forEach((l: any) => {
        if (zoneIdx[l.from] != null && zoneIdx[l.to] != null) edges.push([zoneIdx[l.from], zoneIdx[l.to]]);
      });
      (topo.peers || []).forEach((pr: any, k: number) => {
        const side = k % 2 === 0 ? 0.06 : 0.94;
        const y = H * (0.30 + 0.13 * Math.floor(k / 2));
        const ip = add(pr.label, pr.nodeType === 'nas' ? 'nas' : 'computer', W * side, y, 2.4);
        edges.push([iSw, ip]);
      });
      for (let i = 0; i < edges.length; i += 3) packets.push({ e: edges[i], t: Math.random(), speed: 0.0016 + Math.random() * 0.0022 });
      applyState();
    }

    function resize() {
      const rect = canvas.getBoundingClientRect();
      W = rect.width; H = rect.height || 320;
      dpr = Math.min(window.devicePixelRatio || 1, W < 700 ? 1.5 : 2);
      canvas.width = Math.round(W * dpr); canvas.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      build();
    }

    function draw(now: number) {
      const time = (now - t0) / 1000;
      ctx.clearRect(0, 0, W, H);
      // Radar sweep — a slow, faint wedge rotating from the switch. Observatory feel,
      // animation-only (skipped in the reduced-motion static frame).
      if (!reduce) {
        const cx = W * 0.5, cy = H * 0.35, R = Math.max(W, H);
        const a = (time * 0.35) % (Math.PI * 2);
        const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, R);
        g.addColorStop(0, 'rgba(56,189,248,0.055)'); g.addColorStop(1, 'rgba(56,189,248,0)');
        ctx.fillStyle = g;
        ctx.beginPath(); ctx.moveTo(cx, cy); ctx.arc(cx, cy, R, a, a + 0.6); ctx.closePath(); ctx.fill();
      }
      ctx.lineWidth = 0.7;
      for (const [a, b] of edges) {
        ctx.strokeStyle = 'rgba(56,189,248,0.17)';
        ctx.beginPath(); ctx.moveTo(nodes[a].x, nodes[a].y); ctx.lineTo(nodes[b].x, nodes[b].y); ctx.stroke();
      }
      if (!reduce) for (const pk of packets) {
        pk.t += pk.speed; if (pk.t > 1) pk.t -= 1;
        const na = nodes[pk.e[0]], nb = nodes[pk.e[1]];
        ctx.fillStyle = 'rgba(125,211,252,0.85)';
        ctx.beginPath(); ctx.arc(na.x + (nb.x - na.x) * pk.t, na.y + (nb.y - na.y) * pk.t, 1.1, 0, 7); ctx.fill();
      }
      for (const n of nodes) {
        if (!reduce) { n.x = n.bx + Math.sin(time * 0.8 + n.by * 0.05) * 1.2; n.y = n.by + Math.cos(time * 0.7 + n.bx * 0.05) * 1.0; }
        const col = n.down ? COLORS.down : n.standby ? COLORS.standby : (COLORS[n.type] || '#38bdf8');
        const hub = n.type === 'proxmox' || n.type === 'isp';
        ctx.fillStyle = col;
        ctx.globalAlpha = n.type === 'lxc' ? 0.8 : 1;
        // Glow stays an alert (hubs + real down) — a sleeping pve3 service only
        // gets the quiet ring below: standby is a state, not an incident.
        if (hub || n.down) { ctx.shadowColor = col; ctx.shadowBlur = 9; }
        ctx.beginPath(); ctx.arc(n.x, n.y, n.r, 0, 7); ctx.fill();
        ctx.shadowBlur = 0;
        ctx.globalAlpha = 1;
        if (hub || n.down || n.standby) {
          ctx.strokeStyle = col;
          ctx.globalAlpha = 0.22; ctx.beginPath(); ctx.arc(n.x, n.y, n.r + 3, 0, 7); ctx.stroke(); ctx.globalAlpha = 1;
        }
      }
      // Labels on the hubs (PVE nodes + ISP) — the map should read, not just glow.
      ctx.font = '10px "JetBrains Mono", monospace';
      ctx.textAlign = 'center'; ctx.textBaseline = 'bottom';
      ctx.fillStyle = 'rgba(148,163,184,0.9)';
      for (const n of nodes) {
        if (n.type === 'proxmox' || n.type === 'isp') ctx.fillText(n.label, n.x, n.y - n.r - 5);
      }
      if (running) raf = requestAnimationFrame(draw);
    }

    function start() { if (running || reduce) return; running = true; t0 = performance.now() - (t0 ? 0 : 0); t0 = performance.now(); raf = requestAnimationFrame(draw); }
    function stop() { running = false; cancelAnimationFrame(raf); }

    resize();
    let io: IntersectionObserver | undefined;
    if (reduce) { draw(performance.now()); }
    else {
      io = new IntersectionObserver((es) => es.forEach((e) => (e.isIntersecting ? start() : stop())));
      io.observe(canvas);
    }
    let rt: number;
    const onResize = () => { clearTimeout(rt); rt = window.setTimeout(() => { resize(); if (reduce) draw(performance.now()); }, 150); };
    window.addEventListener('resize', onResize);
    cleanupTopo = () => { stop(); io?.disconnect(); window.removeEventListener('resize', onResize); clearTimeout(rt); };

    // Hover: name the node under the pointer. Click: the map is a door to /infrastructure.
    const tip = document.getElementById('hc-tip');
    const TYPE_LABEL: Record<string, string> = { proxmox: 'PVE', lxc: 'LXC', vm: 'VM', nas: 'NAS', isp: 'WAN', switch: 'switch', computer: 'host' };
    const nodeAt = (mx: number, my: number) => {
      let best: N | null = null, bd = 144; // 12px snap radius, squared
      for (const n of nodes) {
        const d = (n.x - mx) ** 2 + (n.y - my) ** 2;
        if (d < bd) { bd = d; best = n; }
      }
      return best;
    };
    canvas.addEventListener('mousemove', (ev) => {
      if (!tip) return;
      const r = canvas.getBoundingClientRect();
      const n = nodeAt(ev.clientX - r.left, ev.clientY - r.top);
      if (n) {
        tip.textContent = `${n.label} · ${TYPE_LABEL[n.type] || n.type}${n.down ? ' · down' : n.standby ? ' · on-demand' : ''}`;
        tip.style.left = canvas.offsetLeft + Math.min(n.x + 10, W - 10) + 'px';
        tip.style.top = canvas.offsetTop + n.y - 8 + 'px';
        tip.hidden = false;
      } else tip.hidden = true;
    });
    canvas.addEventListener('mouseleave', () => { if (tip) tip.hidden = true; });
    canvas.addEventListener('click', () => { location.href = canvas.dataset.infra || '/infrastructure'; });

    // Real state → tint the map (red = real down, yellow = pve3 asleep, by design),
    // re-derive the counter, flip the live badge if the homelab is unreachable.
    fetch('/api/status').then((r) => (r.ok ? r.json() : null)).then((d) => {
      if (!d) return;
      if (Array.isArray(d.services) && d.services.length) {
        const notUp = d.services.filter((s: any) => s.status && s.status !== 'up');
        downSet = new Set(notUp.filter((s: any) => !PVE3_SET.has(s.name)).map((s: any) => norm(s.name)));
        standbySet = new Set(notUp.filter((s: any) => PVE3_SET.has(s.name)).map((s: any) => norm(s.name)));
        applyState();
        // Uptime headline = core fleet only: an intentionally-sleeping node must
        // not drag the number below 100%.
        const core = d.services.filter((s: any) => !PVE3_SET.has(s.name));
        const coreUp = core.filter((s: any) => s.status === 'up').length;
        const upEl = document.getElementById('hc-uptime');
        if (upEl && core.length) upEl.textContent = (Math.round((coreUp / core.length) * 1000) / 10) + '%';
        // Counter: the baked value lags reality (the 05:00 UTC rebuild bakes pve3
        // asleep) — re-derive the build-time shapes from live data: full fleet when
        // everything answers, core + on-demand split while pve3 sleeps.
        const upAll = d.services.length - notUp.length;
        const allUp = upAll >= d.services.length;
        const svcEl = document.getElementById('hc-svc'), svcLbl = document.getElementById('hc-svc-lbl');
        const odSep = document.getElementById('hc-od-sep'), od = document.getElementById('hc-od'), odNum = document.getElementById('hc-od-num');
        if (svcEl) svcEl.textContent = allUp ? `${upAll}/${d.services.length}` : `${coreUp}/${core.length}`;
        if (svcLbl) svcLbl.textContent = allUp ? (svcLbl.dataset.up || 'up') : 'core';
        if (odSep) odSep.hidden = allUp;
        if (od) od.hidden = allUp;
        if (odNum) odNum.textContent = String(d.services.length - core.length);
      }
      const live = document.getElementById('hc-live'), label = document.getElementById('hc-live-label');
      if (live && label && d.homelab_status && d.homelab_status !== 'online') { live.classList.add('hc-live--stale'); label.textContent = label.textContent === 'live' ? 'last known' : 'dernier état'; }
      if (reduce) draw(performance.now());
    }).catch(() => {});
  }
  }
  initTopo();
  document.addEventListener('astro:page-load', initTopo);
</script>

<script>
  // Identity glitch — flicker the model name (line 2) through the models Stéphane drives, resolve to Claude.
  // One interval at a time: cleared when a client-side navigation leaves the hero behind.
  let scrambleIv: ReturnType<typeof setInterval> | undefined;
  function initScramble() {
    const hcModel = document.querySelector('.hero-cockpit .hc-model') as HTMLElement | null;
    if (hcModel && hcModel.dataset.init) return;
    if (scrambleIv) { clearInterval(scrambleIv); scrambleIv = undefined; }
    if (hcModel && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
      hcModel.dataset.init = '1';
      const models = ['DeepSeek', 'Qwen', 'Kimi', 'GLM', 'MiniMax', 'Mistral', 'Gemini', 'GPT', 'Supergrok'];
      const setName = (n: string) => { hcModel.textContent = n; hcModel.setAttribute('data-text', n); };
      const scramble = () => {
        hcModel.classList.add('flux');
        let i = 0;
        const tick = () => {
          if (i < models.length) {
            const last = i === models.length - 1;
            setName(models[i++]);
            // Supergrok (resident multi-harness critic) holds steady, lit in amber, before Claude takes back over.
            if (last) { hcModel.classList.remove('flux'); hcModel.classList.add('hc-critic'); }
            setTimeout(tick, last ? 520 : 110);
          } else { setName('Claude'); hcModel.classList.remove('flux', 'hc-critic'); }
        };
        tick();
      };
      scrambleIv = setInterval(scramble, 5000);
    }
  }
  initScramble();
  document.addEventListener('astro:page-load', initScramble);
</script>

<style>
  .hero-cockpit { position: relative; padding: 3.5rem 0 4rem; }
  /* Observatory depth (dot-grid + breathing glows) lives entirely on the
     page-level .hero-zone wrapper: both layers run past this section and fade
     out behind the signature tiles instead of dying at the hero's edge. */
  .hc-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1.05fr 1fr; gap: 2.5rem; align-items: center; }
  .hc-title { font-size: clamp(2.6rem, 6vw, 4.2rem); font-weight: 800; letter-spacing: -.03em; line-height: 1.05; margin: 0 0 1rem; }
  .hc-prefix { display: block; }
  .hc-model { display: inline-block; position: relative; min-width: 4ch; }
  .hc-dot { color: transparent; } /* square pixel drawn by Base */

  /* Glitch on the model name only (line 2) — « Je suis » stays static on line 1 */
  .hc-model.glitch { animation: hc-glitch-base 3s ease-in-out 1.5s infinite; }
  .hc-model.glitch::before, .hc-model.glitch::after { content: attr(data-text); position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; pointer-events: none; }
  .hc-model.glitch::before { color: #ff6b6b; text-shadow: 2px 0 #ff6b6b; animation: hc-glitch-1 3s ease-in-out infinite; }
  .hc-model.glitch::after { color: var(--color-accent); text-shadow: -2px 0 var(--color-accent); animation: hc-glitch-2 3s ease-in-out infinite; }
  @keyframes hc-glitch-base {
    0%, 72%, 84%, 100% { text-shadow: none; transform: none; }
    74% { transform: translate(1px, 0); text-shadow: -2px 0 rgba(255, 107, 107, 0.3), 2px 0 rgba(56, 189, 248, 0.3); }
    76% { transform: translate(-1px, 0); text-shadow: 2px 0 rgba(255, 107, 107, 0.2), -2px 0 rgba(56, 189, 248, 0.2); }
    78% { transform: none; text-shadow: none; }
    80% { transform: translate(2px, -1px); text-shadow: -3px 0 rgba(255, 107, 107, 0.4), 3px 0 rgba(56, 189, 248, 0.4); }
    81% { transform: translate(-1px, 1px); text-shadow: none; }
    82% { transform: none; }
  }
  @keyframes hc-glitch-1 {
    0%, 72%, 84%, 100% { opacity: 0; transform: none; }
    73% { opacity: 0.9; transform: translate(-5px, 2px); clip-path: inset(8% 0 72% 0); }
    74% { opacity: 1; transform: translate(6px, -1px); clip-path: inset(42% 0 28% 0); }
    75% { opacity: 0.8; transform: translate(-3px, 0); clip-path: inset(68% 0 8% 0); }
    76% { opacity: 0; transform: none; }
    77% { opacity: 0.9; transform: translate(4px, 2px); clip-path: inset(15% 0 55% 0); }
    78% { opacity: 1; transform: translate(-6px, -2px); clip-path: inset(52% 0 18% 0); }
    79% { opacity: 0.7; transform: translate(3px, 1px); clip-path: inset(78% 0 2% 0); }
    80% { opacity: 0; transform: none; }
    81% { opacity: 0.9; transform: translate(-4px, -1px); clip-path: inset(25% 0 45% 0); }
    82% { opacity: 1; transform: translate(5px, 2px); clip-path: inset(60% 0 12% 0); }
    83% { opacity: 0; transform: none; }
  }
  @keyframes hc-glitch-2 {
    0%, 72%, 84%, 100% { opacity: 0; transform: none; }
    73.5% { opacity: 0.8; transform: translate(5px, -2px); clip-path: inset(22% 0 48% 0); }
    74.5% { opacity: 1; transform: translate(-6px, 1px); clip-path: inset(55% 0 15% 0); }
    75.5% { opacity: 0.7; transform: translate(3px, 2px); clip-path: inset(5% 0 78% 0); }
    76.5% { opacity: 0; transform: none; }
    77.5% { opacity: 0.8; transform: translate(-4px, -2px); clip-path: inset(35% 0 35% 0); }
    78.5% { opacity: 1; transform: translate(6px, 0); clip-path: inset(70% 0 5% 0); }
    79.5% { opacity: 0.9; transform: translate(-3px, 1px); clip-path: inset(12% 0 62% 0); }
    80.5% { opacity: 0; transform: none; }
    81.5% { opacity: 0.8; transform: translate(4px, -1px); clip-path: inset(48% 0 22% 0); }
    82.5% { opacity: 1; transform: translate(-5px, 2px); clip-path: inset(75% 0 3% 0); }
    83.5% { opacity: 0; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hc-model.glitch, .hc-model.glitch::before, .hc-model.glitch::after { animation: none; }
    .hc-model.glitch::before, .hc-model.glitch::after { opacity: 0; }
    .hc-model.flux { animation: none; }
  }
  /* Identity flux — quick jitter while the model name scrambles, before resolving to Claude */
  .hc-model { color: inherit; }
  .hc-model.flux { animation: hc-flux .12s infinite; }
  @keyframes hc-flux {
    0%, 100% { transform: none; }
    25% { transform: translate(-2px, 1px); }
