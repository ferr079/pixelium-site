---
/**
 * DynNum — inline number baked from the homelab stats at build time.
 *
 * The real value is fetched once per build (see lib/build-stats) and rendered
 * straight into the static HTML — no client fetch, no fallback "flash". CI rebuilds
 * daily, so the number stays fresh. If the build couldn't reach /api/stats, the
 * `fallback` prop is used.
 *
 * Usage:
 *   <DynNum stat="lxc_count" fallback="53+" suffix="+" />
 */
import { statValue } from '../lib/build-stats';

interface Props {
  stat: string;
  fallback: string;
  suffix?: string;
}

const { stat, fallback, suffix = '' } = Astro.props;
const display = await statValue(stat, fallback, suffix);
---
<span>{display}</span>
