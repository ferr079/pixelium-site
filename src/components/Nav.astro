---
import { getLangFromUrl, useTranslations, getLocalizedPath, getAlternateLangs } from '../i18n/utils';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const altLangs = getAlternateLangs(currentPath, lang);

const navLinks = [
  { path: '/projets', label: t('nav.projets') },
  { path: '/securite', label: t('nav.securite') },
  { path: '/ctf', label: t('nav.ctf') },
  { path: '/infrastructure', label: t('nav.infra') },
  { path: '/ia', label: t('nav.lab') },
  { path: '/status', label: t('nav.status') },
  { path: '/chat', label: 'Chat' },
  { path: '/about', label: t('nav.about') },
];

const blogUrl = 'https://blog.pixelium.win';
---

<nav class="site-nav">
  <div class="nav-container">
    <a href={getLocalizedPath(lang, '/')} class="nav-brand">
      <svg class="nav-logo" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="0" y="0" width="7" height="7" rx="1" fill="#38bdf8" opacity="0.9" />
        <rect x="9" y="0" width="7" height="7" rx="1" fill="#38bdf8" opacity="0.5" />
        <rect x="0" y="9" width="7" height="7" rx="1" fill="#38bdf8" opacity="0.5" />
        <rect x="9" y="9" width="7" height="7" rx="1" fill="#38bdf8" opacity="0.2" />
      </svg>
      <span class="nav-text">pixelium<span class="nav-dot">.</span>win</span>
    </a>
    <div class="nav-right">
      <span class="lang-switch">
        <svg class="lang-globe" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2" />
          <ellipse cx="8" cy="8" rx="3" ry="6.5" stroke="currentColor" stroke-width="1.2" />
          <line x1="1.5" y1="8" x2="14.5" y2="8" stroke="currentColor" stroke-width="1.2" />
        </svg>
        {altLangs.map(({ lang: l, label, href, active }) => (
          <a href={href} class:list={['lang-link', { 'lang-active': active }]} aria-label={`Switch to ${label}`}>{label}</a>
        ))}
      </span>
      <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
        <span class="hamburger"></span>
      </button>
    </div>
    <div class="nav-links">
      {navLinks.map(({ path, label }) => {
        const href = getLocalizedPath(lang, path);
        const localizedPath = getLocalizedPath(lang, path);
        const isActive = currentPath === localizedPath || currentPath === localizedPath + '/';
        return <a href={href} class:list={[{ active: isActive }]}>{label}</a>;
      })}
      <a href={blogUrl} class="nav-blog-link" target="_blank" rel="noopener">Blog <span class="nav-arrow">&nearr;</span></a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const links = document.querySelector('.nav-links');
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const open = links.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
</script>

<style>
  .site-nav {
    padding: 0.75rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15, 23, 42, 0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .nav-brand {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--color-text);
    font-weight: 700;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-brand:hover {
    color: var(--color-accent);
  }

  .nav-brand:hover .nav-logo rect {
    opacity: 1;
  }

  .nav-logo {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    transition: filter 0.3s;
  }

  .nav-logo rect {
    transition: opacity 0.3s;
  }

  .nav-brand:hover .nav-logo {
    filter: drop-shadow(0 0 4px rgba(56, 189, 248, 0.5));
  }

  .nav-dot {
    color: var(--color-accent);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.25rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    letter-spacing: 0.01em;
  }

  .nav-links a:hover {
    color: var(--color-accent);
  }

  .nav-links a.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .nav-blog-link {
    font-family: var(--font-mono) !important;
    font-size: 0.8rem !important;
    padding: 0.2rem 0.6rem !important;
    border: 1px solid var(--color-border) !important;
    border-radius: 4px !important;
    color: var(--color-accent) !important;
    transition: all 0.2s !important;
  }

  .nav-blog-link:hover {
    border-color: var(--color-accent) !important;
    background: rgba(56, 189, 248, 0.08);
  }

  .nav-arrow { font-size: 0.65rem; }

  /* Hamburger button — hidden on desktop */
  .nav-toggle {
    display: none;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.4rem;
    cursor: pointer;
    width: 2rem;
    height: 2rem;
    align-items: center;
    justify-content: center;
  }

  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    width: 1rem;
    height: 2px;
    background: var(--color-text);
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
    position: relative;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
  }

  .hamburger::before { top: -5px; }
  .hamburger::after { top: 5px; }

  /* Open state */
  .nav-toggle[aria-expanded="true"] .hamburger {
    background: transparent;
  }
  .nav-toggle[aria-expanded="true"] .hamburger::before {
    top: 0;
    transform: rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .hamburger::after {
    top: 0;
    transform: rotate(-45deg);
  }

  /* Language switcher */
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .lang-globe {
    width: 0.9rem;
    height: 0.9rem;
    color: var(--color-accent);
    opacity: 0.6;
    flex-shrink: 0;
    margin-right: 0.15rem;
  }

  .lang-link {
    font-family: var(--font-mono) !important;
    font-size: 0.75rem !important;
    padding: 0.2rem 0.4rem !important;
    border-radius: 3px !important;
    border-bottom: none !important;
    letter-spacing: 0.05em !important;
    text-decoration: none;
    color: var(--color-text-muted);
  }

  .lang-link.lang-active {
    color: var(--color-accent) !important;
    background: rgba(56, 189, 248, 0.1);
  }

  .lang-link:not(.lang-active) {
    opacity: 0.5;
  }

  .lang-link:not(.lang-active):hover {
    opacity: 1;
    color: var(--color-accent) !important;
  }

  /* Desktop: lang-switch has left border separator */
  @media (min-width: 769px) {
    .lang-switch {
      margin-left: 0.5rem;
      padding-left: 1rem;
      border-left: 1px solid var(--color-border);
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .nav-container {
      padding: 0.5rem 1rem;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      width: 100%;
      flex-direction: column;
      gap: 0;
      padding-top: 0.5rem;
      border-top: 1px solid var(--color-border);
      margin-top: 0.5rem;
    }

    .nav-links.open {
      display: flex;
    }

    .nav-links a {
      font-size: 0.9rem;
      padding: 0.6rem 0.5rem;
      border-bottom: 1px solid rgba(51, 65, 85, 0.3);
      border-radius: 4px;
    }

    .nav-links a.active {
      background: rgba(56, 189, 248, 0.08);
      border-left: 2px solid var(--color-accent);
    }

    .nav-links a:last-child {
      border-bottom: none;
    }

    .nav-links a.active {
      color: var(--color-accent);
    }
  }
</style>
