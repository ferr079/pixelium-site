---
import { getBuildStats } from '../lib/build-stats';

interface Props {
  stats: Array<{ number: string; label: string; stat?: string; suffix?: string }>;
}

const { stats } = Astro.props;
const live = await getBuildStats();
// Bake the real value into the static HTML; the count-up animates straight to it
// (no fallback → value flash). Falls back to the hardcoded number if KV had no key.
const resolved = stats.map((s) => ({
  label: s.label,
  display: s.stat && live[s.stat] != null ? `${live[s.stat]}${s.suffix || ''}` : s.number,
}));
---

<section class="stats">
  <div class="stats-container">
    <div class="stats-grid">
      {resolved.map((s, i) => (
        <>
          {i > 0 && <div class="stat-sep"></div>}
          <div class="stat reveal">
            <span class="stat-number" data-target={s.display}>{s.display}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        </>
      ))}
    </div>
  </div>
</section>

<script>
  let statsObserver: IntersectionObserver | null = null;

  function animateCounters() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    // :not([data-armed]) — guard against double-arming (module load + the
    // initial astro:page-load both call this on first render).
    const counters = document.querySelectorAll('.stat-number[data-target]:not([data-armed])');
    if (counters.length === 0) return; // nothing new to arm — keep the live observer intact
    counters.forEach((el) => el.setAttribute('data-armed', '1'));

    // Drop any observer left from a previous page before creating a new one, so
    // View Transitions navigations don't leak detached IntersectionObservers.
    statsObserver?.disconnect();
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          observer.unobserve(el);

          const raw = el.dataset.target || '';
          const match = raw.match(/^([^\d]*)(\d+)(.*)$/);
          if (!match) return;

          const [, prefix, numStr, suffix] = match;
          const target = parseInt(numStr, 10);
          if (target === 0) return;

          const duration = 1500;
          const start = performance.now();

          el.textContent = prefix + '0' + suffix;

          function step(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            // ease-out cubic
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = Math.round(eased * target);
            el.textContent = prefix + current + suffix;
            if (progress < 1) requestAnimationFrame(step);
          }

          requestAnimationFrame(step);
        });
      },
      { threshold: 0.5 }
    );
    statsObserver = observer;

    counters.forEach((el) => observer.observe(el));
  }

  animateCounters();
  // Re-arm on every client-side navigation (fresh DOM).
  document.addEventListener('astro:page-load', animateCounters);
  // Tear the observer down when leaving the page (StatsBar may be absent next).
  document.addEventListener('astro:before-swap', () => {
    statsObserver?.disconnect();
    statsObserver = null;
  });
</script>

<style>
  .stats {
    padding: 2.5rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .stats-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .stats-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    min-width: 8rem;
  }

  .stat-number {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  .stat-sep {
    width: 1px;
    height: 2.5rem;
    background: var(--color-border);
  }

  @media (max-width: 640px) {
    .stat-sep { display: none; }
    .stats-grid { gap: 1.5rem; }
    .stat { min-width: 6rem; }
  }
</style>
