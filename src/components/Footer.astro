      </a>
    </div>
    <nav class="footer-nav" aria-label="More pages">
      <a href={p('/claude')}>{t.claude}</a>
    </nav>
    <p>{t.built} <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> ‚ÄĒ {t.hosted}</p>
    <p class="footer-deploy" aria-label="This deployment">
      <span class="fd-key">&#9622; {t.thisDeploy}</span>
      {commitUrl
        ? <a class="fd-commit" href={commitUrl} target="_blank" rel="noopener" title="View this commit on GitHub">{shaShort}</a>
        : <span class="fd-commit">{shaShort}</span>}
      <span class="fd-sep">¬∑</span>
      <span>{t.builtAt} {builtDisplay}</span>
      <span class="fd-sep">¬∑</span>
      <span class="fd-edge" data-deploy-edge>{t.edge} <span class="fd-colo">‚Ä¶</span></span>
    </p>
    <p class="footer-meta">{t.meta}</p>
  </div>
</footer>

<!-- Scroll to top -->
<button class="scroll-top" aria-label="Scroll to top" id="scrollTop">&#8593;</button>

<script>
  // The footer is replaced on every client-side navigation; keep ONE window
  // scroll listener at module scope pointing at the current button.
  let btn: HTMLElement | null = null;
  window.addEventListener('scroll', () => {
    btn?.classList.toggle('visible', window.scrollY > 400);
  });

  function initFooter() {
    btn = document.getElementById('scrollTop');
    if (btn && !btn.dataset.bound) {
      btn.dataset.bound = '1';
      btn.classList.toggle('visible', window.scrollY > 400);
      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // THIS DEPLOYMENT ‚ÄĒ fill the live edge colo serving this very page
    const edgeEl = document.querySelector('[data-deploy-edge]');
    if (edgeEl && !(edgeEl as HTMLElement).dataset.filled) {
      (edgeEl as HTMLElement).dataset.filled = '1';
      fetch('/api/deployment').then((r) => r.json()).then((d) => {
        const coloEl = edgeEl.querySelector('.fd-colo');
        if (coloEl) coloEl.textContent = d.colo || '??';
        const bits = [d.country && `loc ${d.country}`, d.ray && `ray ${d.ray}`].filter(Boolean);
        if (bits.length) edgeEl.setAttribute('title', bits.join(' ¬∑ '));
      }).catch(() => {});
    }
  }
  initFooter();
  document.addEventListener('astro:page-load', initFooter);
</script>

<style>
  .footer-ascii {
    display: block;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.45rem;
    line-height: 1.1;
    color: var(--color-accent);
    opacity: 0.12;
    margin: 0 auto 1.5rem;
    user-select: none;
    overflow: hidden;
  }

  .site-footer {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 1rem;
  }

  .footer-links a {
    display: flex;
    align-items: center;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .footer-links a:hover {
    opacity: 1;
  }

  .footer-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .footer-nav a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-nav a:hover { color: var(--color-accent); }

  .site-footer p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-align: center;
  }

  .footer-meta {
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem !important;
    color: var(--color-border) !important;
  }

  /* THIS DEPLOYMENT ‚ÄĒ live provenance line */
  .footer-deploy {
    margin-top: 0.8rem !important;
    font-family: var(--font-mono);
    font-size: 0.72rem !important;
    color: var(--color-text-muted) !important;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.4rem;
    line-height: 1.4;
  }

  .footer-deploy .fd-key { opacity: 0.85; }

  .footer-deploy .fd-commit {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px dotted rgba(56, 189, 248, 0.4);
  }

  .footer-deploy .fd-commit:hover { color: var(--color-accent-hover); }

  .footer-deploy .fd-sep { color: var(--color-border); }
  .footer-deploy .fd-colo { color: var(--color-text); }

  /* Scroll to top */
  .scroll-top {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(56, 189, 248, 0.15);
    border: 1px solid rgba(56, 189, 248, 0.3);
    color: var(--color-accent);
    font-size: 1.1rem;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s, background 0.2s;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .scroll-top.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .scroll-top:hover {
    background: rgba(56, 189, 248, 0.3);
  }
</style>
