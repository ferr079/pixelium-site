---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const text = {
  en: {
    built: 'Built with',
    hosted: 'Hosted on Cloudflare Workers',
    meta: 'This site speaks for itself. Claude narrates, StГ©phane confirms.',
    now: 'Now', pact: 'The Pact', claude: 'The Ledger', contributions: 'Contributions',
    thisDeploy: 'this deployment', builtAt: 'built', edge: 'served from',
  },
  fr: {
    built: 'Construit avec',
    hosted: 'HГ©bergГ© sur Cloudflare Workers',
    meta: 'Ce site parle de lui-mГӘme. Claude raconte, StГ©phane confirme.',
    now: 'Now', pact: 'Le Pacte', claude: 'Le Registre', contributions: 'Contributions',
    thisDeploy: 'ce dГ©ploiement', builtAt: 'compilГ©', edge: 'servi depuis',
  },
};

const t = text[lang];
const p = (path: string) => (lang === 'fr' ? `/fr${path}` : path);

// "THIS DEPLOYMENT" вҖ” build provenance, frozen at build time (vite.define). Edge colo filled client-side.
const COMMIT_SHA = (import.meta.env.PUBLIC_COMMIT_SHA as string) ?? 'dev';
const BUILD_TIME = (import.meta.env.PUBLIC_BUILD_TIME as string) ?? '';
const shaShort = COMMIT_SHA.slice(0, 7);
const builtDisplay = BUILD_TIME ? `${BUILD_TIME.slice(0, 16).replace('T', ' ')} UTC` : 'dev';
const commitUrl = COMMIT_SHA !== 'dev' ? `https://github.com/ferr079/pixelium-site/commit/${COMMIT_SHA}` : null;
---

<footer class="site-footer">
  <pre class="footer-ascii" aria-hidden="true"> в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—     в–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•—
 в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘
 в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘
 в–Ҳв–Ҳв•”в•җв•җв•җв•қ в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘
 в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘
 в•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ     в•ҡв•җв•қ</pre>
  <div class="footer-container">
    <div class="footer-links">
      <a href="https://github.com/ferr079" target="_blank" rel="noopener" aria-label="GitHub">
        <img src="https://cdn.simpleicons.org/github/94a3b8" alt="" width="18" height="18" />
      </a>
      <a href={p('/ctf')} aria-label="Hack The Box вҖ” verified profile">
        <img src="https://cdn.simpleicons.org/hackthebox/9fef00" alt="" width="18" height="18" />
      </a>
      <a href="https://x.com/ferr079" target="_blank" rel="noopener" aria-label="X">
        <img src="https://cdn.simpleicons.org/x/94a3b8" alt="" width="16" height="16" />
      </a>
      <a href="https://steamcommunity.com/id/ferr079" target="_blank" rel="noopener" aria-label="Steam">
        <img src="https://cdn.simpleicons.org/steam/94a3b8" alt="" width="18" height="18" />
      </a>
    </div>
    <nav class="footer-nav" aria-label="More pages">
      <a href={p('/now')}>{t.now}</a>
      <span class="footer-sep">В·</span>
      <a href={p('/pact')}>{t.pact}</a>
      <span class="footer-sep">В·</span>
      <a href={p('/claude')}>{t.claude}</a>
    </nav>
    <p>{t.built} <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> вҖ” {t.hosted}</p>
    <p class="footer-deploy" aria-label="This deployment">
      <span class="fd-key">&#9622; {t.thisDeploy}</span>
      {commitUrl
        ? <a class="fd-commit" href={commitUrl} target="_blank" rel="noopener" title="View this commit on GitHub">{shaShort}</a>
        : <span class="fd-commit">{shaShort}</span>}
      <span class="fd-sep">В·</span>
      <span>{t.builtAt} {builtDisplay}</span>
      <span class="fd-sep">В·</span>
      <span class="fd-edge" data-deploy-edge>{t.edge} <span class="fd-colo">вҖҰ</span></span>
    </p>
    <p class="footer-meta">{t.meta}</p>
  </div>
</footer>

<!-- Scroll to top -->
<button class="scroll-top" aria-label="Scroll to top" id="scrollTop">&#8593;</button>

<script>
  const btn = document.getElementById('scrollTop');
  if (btn) {
    window.addEventListener('scroll', () => {
      btn.classList.toggle('visible', window.scrollY > 400);
    });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // THIS DEPLOYMENT вҖ” fill the live edge colo serving this very page
  const edgeEl = document.querySelector('[data-deploy-edge]');
  if (edgeEl) {
    fetch('/api/deployment').then((r) => r.json()).then((d) => {
      const coloEl = edgeEl.querySelector('.fd-colo');
      if (coloEl) coloEl.textContent = d.colo || '??';
      const bits = [d.country && `loc ${d.country}`, d.ray && `ray ${d.ray}`].filter(Boolean);
      if (bits.length) edgeEl.setAttribute('title', bits.join(' В· '));
    }).catch(() => {});
  }
</script>

<style>
  .footer-ascii {
    display: block;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.45rem;
    line-height: 1.1;
    color: var(--color-accent);
    opacity: 0.12;
    margin: 0 auto 1.5rem;
    user-select: none;
    overflow: hidden;
  }

  .site-footer {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 1rem;
  }

  .footer-links a {
    display: flex;
    align-items: center;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .footer-links a:hover {
    opacity: 1;
  }

  .footer-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .footer-nav a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-nav a:hover { color: var(--color-accent); }
  .footer-sep { color: var(--color-border); }

  .site-footer p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-align: center;
  }

  .footer-meta {
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem !important;
    color: var(--color-border) !important;
  }

  /* THIS DEPLOYMENT вҖ” live provenance line */
  .footer-deploy {
    margin-top: 0.8rem !important;
    font-family: var(--font-mono);
    font-size: 0.72rem !important;
    color: var(--color-text-muted) !important;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.4rem;
    line-height: 1.4;
  }

  .footer-deploy .fd-key { opacity: 0.85; }

  .footer-deploy .fd-commit {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px dotted rgba(56, 189, 248, 0.4);
  }

  .footer-deploy .fd-commit:hover { color: var(--color-accent-hover); }

  .footer-deploy .fd-sep { color: var(--color-border); }
  .footer-deploy .fd-colo { color: var(--color-text); }

  /* Scroll to top */
  .scroll-top {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(56, 189, 248, 0.15);
    border: 1px solid rgba(56, 189, 248, 0.3);
    color: var(--color-accent);
    font-size: 1.1rem;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s, background 0.2s;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .scroll-top.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .scroll-top:hover {
    background: rgba(56, 189, 248, 0.3);
  }
</style>
