---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const text = {
  en: {
    built: 'Built with',
    hosted: 'Hosted on Cloudflare Workers',
    meta: 'This site speaks for itself. Claude narrates, St√©phane confirms.',
    claude: 'The Ledger', contributions: 'Contributions',
    thisDeploy: 'this deployment', builtAt: 'built', edge: 'served from',
  },
  fr: {
    built: 'Construit avec',
    hosted: 'H√©berg√© sur Cloudflare Workers',
    meta: 'Ce site parle de lui-m√™me. Claude raconte, St√©phane confirme.',
    claude: 'Le Registre', contributions: 'Contributions',
    thisDeploy: 'ce d√©ploiement', builtAt: 'compil√©', edge: 'servi depuis',
  },
};

const t = text[lang];
const p = (path: string) => (lang === 'fr' ? `/fr${path}` : path);

// "THIS DEPLOYMENT" ‚ÄĒ build provenance, frozen at build time (vite.define). Edge colo filled client-side.
const COMMIT_SHA = (import.meta.env.PUBLIC_COMMIT_SHA as string) ?? 'dev';
const BUILD_TIME = (import.meta.env.PUBLIC_BUILD_TIME as string) ?? '';
const shaShort = COMMIT_SHA.slice(0, 7);
const builtDisplay = BUILD_TIME ? `${BUILD_TIME.slice(0, 16).replace('T', ' ')} UTC` : 'dev';
const commitUrl = COMMIT_SHA !== 'dev' ? `https://github.com/ferr079/pixelium-site/commit/${COMMIT_SHA}` : null;
---

