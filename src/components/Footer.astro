---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const text = {
  en: {
    built: 'Built with',
    hosted: 'Hosted on Cloudflare Workers',
    meta: 'This site speaks for itself. Claude narrates, Stéphane confirms.',
  },
  fr: {
    built: 'Construit avec',
    hosted: 'Hébergé sur Cloudflare Workers',
    meta: 'Ce site parle de lui-même. Claude raconte, Stéphane confirme.',
  },
};

const t = text[lang];
---

<footer class="site-footer">
  <div class="footer-container">
    <p>{t.built} <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> — {t.hosted}</p>
    <p class="footer-meta">{t.meta}</p>
  </div>
</footer>

<style>
  .site-footer {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .site-footer p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-align: center;
  }

  .footer-meta {
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem !important;
    color: var(--color-border) !important;
  }
</style>
