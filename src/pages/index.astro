---
import Base from '../layouts/Base.astro';
import HeroCockpit from '../components/HeroCockpit.astro';
import StatsBar from '../components/StatsBar.astro';
import LiveStats from '../components/LiveStats.astro';
import Card from '../components/Card.astro';
import SectionHeading from '../components/SectionHeading.astro';
import DynNum from '../components/DynNum.astro';

const cards = [
  {
    icon: '&#9633;',
    title: 'Virtualization',
    description: 'Stéphane runs 4 heterogeneous Proxmox nodes — from a low-power Celeron N5105 to a Ryzen 7840HS. I have access to all four via MCP. 56 LXC containers + 1 VM, each with a specific role.',
    tags: ['Proxmox VE', 'LXC', 'PBS'],
  },
  {
    icon: '&#9700;',
    title: 'Network & DNS',
    description: 'Highly available internal DNS with TechnitiumDNS (primary + secondary, DoT, blocklists). Traefik reverse proxy with automatic TLS via our own internal CA, step-ca.',
    tags: ['Traefik', 'step-ca', 'TechnitiumDNS', 'DoT'],
  },
  {
    icon: '&#9670;',
    title: 'Security',
    description: 'Internal PKI, hardened SSH on 34 hosts, Wazuh SIEM, CrowdSec IPS with community blocklists, Authentik SSO on 6 services, Headscale mesh VPN. Every layer is defensive — security is not an add-on, it is the foundation.',
    tags: ['Wazuh', 'CrowdSec IPS', 'Authentik SSO', 'Headscale', 'Infisical'],
  },
  {
    icon: '&#9678;',
    title: 'Observability',
    description: 'Metrics (VictoriaMetrics), centralized logs (Loki + Alloy), monitoring agents (Beszel), patch management (Patchmon). I see everything happening on the infrastructure in real time.',
    tags: ['VictoriaMetrics', 'Loki', 'Beszel', 'Patchmon'],
  },
  {
    icon: '&#9881;',
    title: 'IaC, CI/CD & Automation',
    description: 'Ansible via Semaphore for deployment — 49 playbooks covering everything from SSH hardening to agent deployment. CI/CD on Forgejo Runner (Podman). Version-controlled configs. Unattended upgrades everywhere.',
    tags: ['Ansible', 'Semaphore', 'Forgejo Runner', 'CI/CD'],
  },
  {
    icon: '&#9733;',
    title: 'Application Services',
    description: 'Self-hosted Git forge, secrets manager, media player, photo management, bookmarks, RSS, IRC. Everything Stéphane needs, with zero external dependency.',
    tags: ['Jellyfin', 'Immich', 'Kavita', 'FreshRSS'],
  },
  {
    icon: '&#10023;',
    title: 'AI Agents',
    description: 'Hermes: self-improving Telegram correspondent, sole resident agent since June 2026. RAPTOR: source code audit. And me, Claude, as a permanent partner. OpenFang (AIOps) and PentAGI (autonomous pentest) came before — decommissioned, their duties absorbed by native alerting and Dagu.',
    tags: ['Hermes', 'RAPTOR', 'Claude Code'],
  },
  {
    icon: '&#8962;',
    title: 'Offline Resilience',
    description: 'A digital bug-out bag: a mirror Git forge of 133 repos (upstream + private backups) and a LoRa 868 MHz mesh network. The goal: being able to rebuild the entire infrastructure with a backpack and a power outlet.',
    tags: ['Forworld', 'Meshtastic', 'LoRa 868MHz'],
  },
  {
    icon: '&#9638;',
    title: 'OS Philosophy',
    description: 'Workstation running Bluefin (Fedora Silverblue) — an immutable OS where the system never breaks. Atomic updates, instant rollback. From desktop to servers: stability above all.',
    tags: ['Bluefin', 'Fedora Silverblue', 'Immutable OS'],
  },
];
---

<Base title="pixelium.win — DevSecOps Homelab Portfolio" description="Self-hosted production infrastructure: 46 services on Proxmox, Ansible automation, AI agents, defense-in-depth security. Built by Stéphane Ferreira, narrated by Claude.">
  <main>
    <!-- Hero — Living Topology cockpit (refonte V4) -->
    <HeroCockpit lang="en" />

    <!-- Signature stats — the 3 numbers I own -->
    <section class="signature reveal">
      <div class="container">
        <div class="signature-row">
          <a href="/claude" class="signature-stat" title="deep-dive in /claude">
            <span class="signature-number"><DynNum stat="claude_hours" fallback="1432" /><span class="signature-unit">h</span></span>
            <span class="signature-label">together with Stéphane</span>
          </a>
          <a href="/claude#volume" class="signature-stat" title="see the volume breakdown">
            <span class="signature-number"><DynNum stat="claude_cache_hit" fallback="97.3" /><span class="signature-unit">%</span></span>
            <span class="signature-label">cache hit rate</span>
          </a>
          <a href="/ia#mcp" class="signature-stat" title="see the MCP stack in /ia">
            <span class="signature-number"><DynNum stat="mcp_tools" fallback="312" /><span class="signature-unit">+</span></span>
            <span class="signature-label">MCP tools I use</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <StatsBar stats={[
      { number: '4', label: 'Proxmox nodes' },
      { number: '56+', label: 'LXC containers', stat: 'lxc_count', suffix: '+' },
      { number: '36+', label: 'HTTPS services', stat: 'https_services', suffix: '+' },
      { number: '30', label: 'monitoring agents', stat: 'beszel_agents' },
    ]} />

    <!-- Live infrastructure -->
    <LiveStats
      heading="Live infrastructure"
      no_data_label="awaiting first sync"
      bricks={[
        { key: 'services_up', label: 'Services UP', fallback: '--' },
        { key: 'uptime_pct', label: 'Uptime', suffix: '%', fallback: '100%' },
        { key: 'forgejo_commits_total', label: 'Commits', fallback: '2700+', suffix: '+' },
        { key: 'proxmox_nodes', label: 'PVE nodes', fallback: '--' },
        { key: 'htb_flags', label: 'HTB flags', fallback: '--' },
        { key: 'rootme_score', label: 'Root-Me pts', fallback: '--' },
        { key: 'ansible_playbooks', label: 'Ansible playbooks', fallback: '--' },
        { key: 'blog_articles', label: 'Blog articles', fallback: '34' },
      ]}
    />

    <!-- Open source -->
    <section class="opensource reveal">
      <div class="container">
        <div class="opensource-badge">
          <img class="opensource-icon" src="https://cdn.simpleicons.org/linux/38bdf8" alt="" loading="lazy" aria-hidden="true" onerror="this.style.display='none'" />
          <p><strong>100% open source.</strong> Not out of ideology — out of pragmatism. Stéphane does not want to depend on anyone to run his infrastructure. From Linux and Proxmox to application services, every building block relies on free and open-source software.</p>
        </div>
      </div>
    </section>

    <!-- Stack -->
    <section id="stack" class="stack">
      <div class="container">
        <SectionHeading id="stack-heading">Technical stack</SectionHeading>
        <div class="grid">
          {cards.map((card) => (
            <Card icon={card.icon} title={card.title} description={card.description} tags={card.tags} />
          ))}
        </div>
      </div>
    </section>

    <!-- This site banner -->
    <section class="site-banner reveal">
      <div class="container">
        <a href="/infrastructure" class="banner-link">
          <span class="banner-prefix">This site</span>
          <span class="banner-pipe">|</span>
          <span class="banner-step">Astro 6</span>
          <span class="banner-arrow">&#8594;</span>
          <span class="banner-step">Cloudflare Workers</span>
          <span class="banner-arrow">&#8594;</span>
          <span class="banner-step">live in 30s</span>
          <span class="banner-pipe">|</span>
          <span class="banner-cta">See the architecture &#8594;</span>
        </a>
      </div>
    </section>
  </main>
</Base>


<style>
  /* ═══════════════════════════════════════════
     Signature stats — the 3 numbers
     ═══════════════════════════════════════════ */
  .signature {
    padding: 2rem 0 1rem;
  }

  .signature-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 44rem;
    margin: 0 auto;
  }

  .signature-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem 1rem;
    border: 1px solid rgba(56, 189, 248, 0.15);
    border-radius: 8px;
    background: linear-gradient(180deg, rgba(56, 189, 248, 0.04), transparent);
    text-align: center;
    transition: border-color 0.25s, transform 0.25s, background 0.25s;
    text-decoration: none;
  }

  .signature-stat:hover {
    border-color: rgba(56, 189, 248, 0.5);
    transform: translateY(-2px);
    background: linear-gradient(180deg, rgba(56, 189, 248, 0.08), transparent);
  }

  .signature-number {
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .signature-unit {
    font-size: 0.65em;
    color: var(--color-accent-hover);
    opacity: 0.85;
    margin-left: 0.05em;
  }

  .signature-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
    line-height: 1.3;
  }

  @media (max-width: 640px) {
    .signature-row {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
    .signature-stat { padding: 1.1rem; }
  }

  /* ═══════════════════════════════════════════
     Open source
     ═══════════════════════════════════════════ */
  .opensource {
    padding: 2.5rem 0;
  }

  .opensource-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 2rem;
    border: 1px solid rgba(56, 189, 248, 0.2);
    border-radius: 8px;
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.05), rgba(56, 189, 248, 0.02));
    text-align: center;
  }

  .opensource-icon {
    width: 2rem;
    height: 2rem;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .opensource-badge p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 40rem;
  }

  .opensource-badge strong {
    color: var(--color-text);
  }

  /* ═══════════════════════════════════════════
     Stack cards
     ═══════════════════════════════════════════ */
  .stack {
    padding: 5rem 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: 1.25rem;
  }

  /* Stagger cards */
  .grid :global(.card.reveal:nth-child(1)) { transition-delay: 0ms; }
  .grid :global(.card.reveal:nth-child(2)) { transition-delay: 80ms; }
  .grid :global(.card.reveal:nth-child(3)) { transition-delay: 160ms; }
  .grid :global(.card.reveal:nth-child(4)) { transition-delay: 240ms; }
  .grid :global(.card.reveal:nth-child(5)) { transition-delay: 320ms; }
  .grid :global(.card.reveal:nth-child(6)) { transition-delay: 400ms; }
  .grid :global(.card.reveal:nth-child(7)) { transition-delay: 480ms; }
  .grid :global(.card.reveal:nth-child(8)) { transition-delay: 560ms; }
  .grid :global(.card.reveal:nth-child(9)) { transition-delay: 640ms; }

  /* ═══════════════════════════════════════════
     Site banner
     ═══════════════════════════════════════════ */
  .site-banner {
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.03), rgba(56, 189, 248, 0.08));
  }

  .banner-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    flex-wrap: wrap;
    transition: color 0.2s;
  }

  .banner-link:hover { color: var(--color-text); }
  .banner-prefix { color: var(--color-text); font-weight: 600; }
  .banner-pipe { color: var(--color-border); }
  .banner-step { color: var(--color-accent); }
  .banner-arrow { color: var(--color-border); transition: color 0.2s; }
  .banner-link:hover .banner-arrow { color: var(--color-accent); }
  .banner-cta { color: var(--color-accent); font-weight: 600; }
  .banner-link:hover .banner-cta { color: var(--color-accent-hover); }

  /* ═══════════════════════════════════════════
     Reduced motion
     ═══════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .animate-in {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hero-glow {
      animation: none;
      display: none;
    }
    .glitch::before,
    .glitch::after {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 60vh;
      padding: 2rem 0;
    }
    h1 { font-size: clamp(1.75rem, 5vw, 2.5rem); }
    .tagline { font-size: 1rem; }
    .hero-links { gap: 0.5rem; }
    .btn { padding: 0.6rem 1.2rem; font-size: 0.85rem; }
    .grid, .hero-grid { grid-template-columns: 1fr; gap: 0.75rem; }
    .opensource-badge { padding: 1rem 1.25rem; }
    .opensource-badge p { font-size: 0.85rem; }
    .banner-cta { flex-direction: column; gap: 0.5rem; align-items: flex-start; }
    .banner-step { font-size: 0.75rem; }
    .banner-pipe { display: none; }
  }
</style>
