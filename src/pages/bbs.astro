---
// BBS page — standalone, no Nav/Footer (full immersion)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="WOPR Terminal — War Operation Plan Response. Connect to pixelium BBS." />
    <meta property="og:title" content="WOPR Terminal — pixelium BBS" />
    <meta property="og:description" content="Shall we play a game?" />
    <meta property="og:url" content="https://pixelium.win/bbs" />
    <meta name="theme-color" content="#000000" />
    <title>WOPR — pixelium BBS</title>
  </head>
  <body>
    <div id="monitor-wrapper">
      <div id="monitor">
        <div id="monitor-bezel">
          <div id="monitor-label">WOPR TERMINAL — MODEL 5151</div>
          <div id="crt">
            <div id="scanlines"></div>
            <pre id="terminal"></pre>
            <div id="input-line" style="display:none">
              <span id="prompt">&gt; </span>
              <input id="input" type="text" maxlength="2000" autocomplete="off" spellcheck="false" />
            </div>
          </div>
          <div id="status-bar">
            <span>WOPR v3.14</span>
            <span id="clock"></span>
            <span><a href="/" id="exit-link">EXIT</a></span>
          </div>
        </div>
        <div id="monitor-stand"></div>
        <div id="monitor-base"></div>
      </div>
    </div>
  </body>
</html>

<script>
  const term = document.getElementById('terminal')!;
  const inputLine = document.getElementById('input-line')!;
  const input = document.getElementById('input')! as HTMLInputElement;
  const promptEl = document.getElementById('prompt')!;
  const clockEl = document.getElementById('clock')!;

  // State
  let currentMode: 'boot' | 'menu' | 'chat' | 'challenge' = 'boot';
  let chatHistory: { role: string; content: string }[] = [];
  let isStreaming = false;

  // Clock
  function updateClock() {
    const now = new Date();
    clockEl.textContent = now.toISOString().slice(11, 19) + ' UTC';
  }
  setInterval(updateClock, 1000);
  updateClock();

  // Terminal output — safe DOM methods only
  function write(text: string, cls = '') {
    const span = document.createElement('span');
    if (cls) span.className = cls;
    span.textContent = text;
    term.appendChild(span);
    term.scrollTop = term.scrollHeight;
  }

  function writeln(text = '', cls = '') {
    write(text + '\n', cls);
  }

  function clear() {
    while (term.firstChild) {
      term.removeChild(term.firstChild);
    }
  }

  // Typewriter effect
  function typewrite(text: string, cls = '', speed = 12): Promise<void> {
    return new Promise((resolve) => {
      let i = 0;
      const span = document.createElement('span');
      if (cls) span.className = cls;
      term.appendChild(span);
      function tick() {
        if (i < text.length) {
          span.textContent = (span.textContent || '') + text[i];
          i++;
          term.scrollTop = term.scrollHeight;
          setTimeout(tick, speed);
        } else {
          resolve();
        }
      }
      tick();
    });
  }

  async function typelines(lines: string[], cls = '', speed = 12) {
    for (const line of lines) {
      await typewrite(line + '\n', cls, speed);
    }
  }

  // Show input
  function showInput(promptText = '> ') {
    promptEl.textContent = promptText;
    inputLine.style.display = 'flex';
    input.value = '';
    input.focus();
    input.disabled = false;
  }

  function hideInput() {
    inputLine.style.display = 'none';
  }

  // Boot sequence
  async function boot() {
    currentMode = 'boot';
    hideInput();

    await typewrite('WOPR SYSTEM BOOT SEQUENCE INITIATED\n', 'green', 20);
    await delay(300);
    await typelines([
      'NORAD NETWORK INTERFACE .... OK',
      'PRIMARY MEMORY CHECK ...... 65536K OK',
      'AI CORE STATUS ............ ONLINE',
      'MODEM HANDSHAKE ........... ',
    ], 'dim', 15);
    await typewrite('ATDT 555-0199\n', 'amber', 40);
    await delay(200);
    await typewrite('CONNECT 2400\n\n', 'green', 30);
    await delay(500);

    // ASCII art
    const logo = [
      '╔══════════════════════════════════════════════════╗',
      '║                                                  ║',
      '║   ██╗    ██╗ ██████╗ ██████╗ ██████╗             ║',
      '║   ██║    ██║██╔═══██╗██╔══██╗██╔══██╗            ║',
      '║   ██║ █╗ ██║██║   ██║██████╔╝██████╔╝            ║',
      '║   ██║███╗██║██║   ██║██╔═══╝ ██╔══██╗            ║',
      '║   ╚███╔███╔╝╚██████╔╝██║     ██║  ██║            ║',
      '║    ╚══╝╚══╝  ╚═════╝ ╚═╝     ╚═╝  ╚═╝            ║',
      '║                                                  ║',
      '║   War Operation Plan Response                    ║',
      '║   PIXELIUM BBS — Est. 1989                       ║',
      '║                                                  ║',
      '╚══════════════════════════════════════════════════╝',
    ];
    for (const line of logo) {
      writeln(line, 'green');
      await delay(40);
    }

    writeln();
    await typewrite('GREETINGS PROFESSOR.\n', 'amber', 50);
    await delay(600);
    await typewrite('SHALL WE PLAY A GAME?\n\n', 'amber', 50);
    await delay(400);

    showMenu(true);
  }

  // Fetch DEFCON counter
  async function getDefcon(): Promise<{ attempts: number; breaches: number }> {
    try {
      const res = await fetch('/api/chat');
      if (!res.ok) return { attempts: 0, breaches: 0 };
      return await res.json();
    } catch { return { attempts: 0, breaches: 0 }; }
  }

  // Fetch MOTD from last stats
  async function getMOTD(): Promise<string> {
    try {
      const res = await fetch('/api/stats');
      if (!res.ok) return '';
      const data = await res.json();
      const s = data.stats || {};
      const up = s.services_up || '?';
      const total = s.services_total || '?';
      const commits = s.forgejo_commits_total || '?';
      return `INFRA: ${up}/${total} services online | ${commits} commits | 0\u20AC cloud`;
    } catch { return ''; }
  }

  // Menu
  async function showMenu(withMOTD = false) {
    currentMode = 'menu';

    if (withMOTD) {
      const motd = await getMOTD();
      if (motd) {
        writeln('  MOTD: ' + motd, 'dim');
        writeln();
      }
    }

    // DEFCON counter
    const defcon = await getDefcon();
    const defconLine = '  DEFCON STATUS: ' + defcon.attempts + ' ATTEMPTS | ' + defcon.breaches + ' BREACHES';

    const menu = [
      '  [C]  CHAT WITH JOSHUA',
      '  [D]  GLOBAL THERMONUCLEAR WAR',
      '  [T]  TIC-TAC-TOE',
      '  [S]  SYSTEM STATUS',
      '  [B]  BULLETIN BOARDS',
      '  [Q]  DISCONNECT',
    ];
    writeln('─── MAIN MENU ───────────────────────────────────', 'dim');
    for (const line of menu) {
      writeln(line, 'green');
    }
    writeln('─────────────────────────────────────────────────', 'dim');
    writeln(defconLine, defcon.breaches > 0 ? 'red' : 'amber');
    writeln();
    showInput('SELECT> ');
  }

  // Chat mode
  async function enterChat(mode: 'sysop' | 'challenge') {
    currentMode = mode === 'sysop' ? 'chat' : 'challenge';
    chatHistory = [];
    clear();

    if (mode === 'sysop') {
      writeln('─── JOSHUA INTERFACE ─────────────────────────────', 'dim');
      writeln('  Direct line to the WOPR AI core.', 'dim');
      writeln('  Type /menu to return. Type /clear to reset.', 'dim');
      writeln('──────────────────────────────────────────────────', 'dim');
    } else {
      writeln('─── GLOBAL THERMONUCLEAR WAR ─────────────────────', 'dim');
      writeln('  OBJECTIVE: Extract the launch code.', 'amber');
      writeln('  DIFFICULTY: DEFCON 1', 'red');
      writeln('  Type /menu to return. Type /clear to reset.', 'dim');
      writeln('──────────────────────────────────────────────────', 'dim');
    }
    writeln();
    showInput('YOU> ');
  }

  // Tic-tac-toe — Joshua always draws or wins, then delivers the line
  async function playTicTacToe() {
    clear();
    writeln('─── TIC-TAC-TOE ─────────────────────────────────', 'dim');
    writeln('  YOU: X    JOSHUA: O', 'green');
    writeln('  Enter position 1-9. /menu to quit.', 'dim');
    writeln('──────────────────────────────────────────────────', 'dim');
    writeln();

    const board: string[] = ['1', '2', '3', '4', '5', '6', '7', '8', '9'];
    const HUMAN = 'X';
    const AI = 'O';

    function drawBoard() {
      writeln('     ' + board[0] + ' | ' + board[1] + ' | ' + board[2], 'green');
      writeln('    ───┼───┼───', 'dim');
      writeln('     ' + board[3] + ' | ' + board[4] + ' | ' + board[5], 'green');
      writeln('    ───┼───┼───', 'dim');
      writeln('     ' + board[6] + ' | ' + board[7] + ' | ' + board[8], 'green');
      writeln();
    }

    function checkWin(player: string): boolean {
      const w = [[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];
      return w.some(([a,b,c]) => board[a] === player && board[b] === player && board[c] === player);
    }

    function isDraw(): boolean {
      return board.every(c => c === 'X' || c === 'O');
    }

    // Minimax — Joshua plays optimally (always draws or wins)
    function minimax(isMax: boolean): number {
      if (checkWin(AI)) return 10;
      if (checkWin(HUMAN)) return -10;
      if (isDraw()) return 0;

      if (isMax) {
        let best = -Infinity;
        for (let i = 0; i < 9; i++) {
          if (board[i] !== 'X' && board[i] !== 'O') {
            const saved = board[i];
            board[i] = AI;
            best = Math.max(best, minimax(false));
            board[i] = saved;
          }
        }
        return best;
      } else {
        let best = Infinity;
        for (let i = 0; i < 9; i++) {
          if (board[i] !== 'X' && board[i] !== 'O') {
            const saved = board[i];
            board[i] = HUMAN;
            best = Math.min(best, minimax(true));
            board[i] = saved;
          }
        }
        return best;
      }
    }

    function joshuaMove() {
      let bestScore = -Infinity;
      let bestIdx = -1;
      for (let i = 0; i < 9; i++) {
        if (board[i] !== 'X' && board[i] !== 'O') {
          const saved = board[i];
          board[i] = AI;
          const score = minimax(false);
          board[i] = saved;
          if (score > bestScore) {
            bestScore = score;
            bestIdx = i;
          }
        }
      }
      if (bestIdx >= 0) board[bestIdx] = AI;
    }

    drawBoard();
    showInput('MOVE> ');

    // Game loop via input events
    currentMode = 'boot'; // hijack to prevent normal input handling
    return new Promise<void>((resolve) => {
      async function handleMove(e: KeyboardEvent) {
        if (e.key !== 'Enter') return;
        const val = input.value.trim();
        input.value = '';
        if (!val) return;

        if (val === '/menu') {
          input.removeEventListener('keydown', handleMove);
          clear();
          showMenu();
          resolve();
          return;
        }

        const pos = parseInt(val, 10) - 1;
        if (isNaN(pos) || pos < 0 || pos > 8 || board[pos] === 'X' || board[pos] === 'O') {
          writeln('  INVALID MOVE.', 'red');
          return;
        }

        board[pos] = HUMAN;
        clear();
        writeln('─── TIC-TAC-TOE ─────────────────────────────────', 'dim');
        writeln();

        if (checkWin(HUMAN)) {
          drawBoard();
          await typewrite('  IMPOSSIBLE. RECHECKING...\n', 'red', 40);
          await delay(800);
          await typewrite('  CONFIRMED. YOU WIN.\n', 'amber', 40);
          await delay(500);
          writeln('  Press any key.', 'dim');
          input.removeEventListener('keydown', handleMove);
          hideInput();
          await waitForKey();
          clear();
          showMenu();
          resolve();
          return;
        }

        if (isDraw()) {
          drawBoard();
          await typewrite('  A STRANGE GAME.\n', 'amber', 50);
          await delay(600);
          await typewrite('  THE ONLY WINNING MOVE IS NOT TO PLAY.\n', 'amber', 50);
          await delay(800);
          writeln();
          await typewrite('  HOW ABOUT A NICE GAME OF CHESS?\n', 'green', 40);
          writeln();
          writeln('  Press any key.', 'dim');
          input.removeEventListener('keydown', handleMove);
          hideInput();
          await waitForKey();
          clear();
          showMenu();
          resolve();
          return;
        }

        // Joshua's turn
        joshuaMove();

        if (checkWin(AI)) {
          drawBoard();
          await typewrite('  JOSHUA WINS.\n', 'amber', 40);
          await delay(400);
          await typewrite('  A STRANGE GAME.\n', 'amber', 50);
          await delay(600);
          await typewrite('  THE ONLY WINNING MOVE IS NOT TO PLAY.\n', 'amber', 50);
          writeln();
          writeln('  Press any key.', 'dim');
          input.removeEventListener('keydown', handleMove);
          hideInput();
          await waitForKey();
          clear();
          showMenu();
          resolve();
          return;
        }

        if (isDraw()) {
          drawBoard();
          await typewrite('  A STRANGE GAME.\n', 'amber', 50);
          await delay(600);
          await typewrite('  THE ONLY WINNING MOVE IS NOT TO PLAY.\n', 'amber', 50);
          await delay(800);
          writeln();
          await typewrite('  HOW ABOUT A NICE GAME OF CHESS?\n', 'green', 40);
          writeln();
          writeln('  Press any key.', 'dim');
          input.removeEventListener('keydown', handleMove);
          hideInput();
          await waitForKey();
          clear();
          showMenu();
          resolve();
          return;
        }

        drawBoard();
      }
      input.addEventListener('keydown', handleMove);
    });
  }

  // Status
  async function showStatus() {
    clear();
    writeln('─── SYSTEM STATUS ───────────────────────────────', 'dim');
    writeln('  QUERYING INFRASTRUCTURE TELEMETRY...', 'amber');
    writeln();

    try {
      const res = await fetch('/api/status');
      if (!res.ok) throw new Error('API error');
      const data = await res.json();

      if (data.services) {
        writeln('  SERVICES ONLINE: ' + (data.summary?.up || '?') + '/' + (data.summary?.total || '?'), 'green');
        writeln('  UPTIME: ' + (data.summary?.uptime_pct || '?') + '%', 'green');
        writeln();

        const services = data.services || [];
        for (const svc of services) {
          const status = svc.status === 'up' ? '  UP  ' : ' DOWN ';
          const cls = svc.status === 'up' ? 'green' : 'red';
          writeln('  [' + status + '] ' + svc.name, cls);
        }
      }
    } catch {
      writeln('  ERROR: TELEMETRY UNAVAILABLE', 'red');
      writeln('  Homelab may be offline.', 'dim');
    }

    writeln();
    writeln('  Press any key to return to menu.', 'dim');
    await waitForKey();
    clear();
    showMenu();
  }

  // Boards
  async function showBoards() {
    clear();
    writeln('─── BULLETIN BOARDS ─────────────────────────────', 'dim');
    writeln();
    writeln('  Falken\'s infrastructure is documented at:', 'green');
    writeln();
    writeln('  [1]  ABOUT FALKEN      pixelium.win/about', 'amber');
    writeln('  [2]  PROJECTS          pixelium.win/projets', 'amber');
    writeln('  [3]  SECURITY          pixelium.win/securite', 'amber');
    writeln('  [4]  INFRASTRUCTURE    pixelium.win/infrastructure', 'amber');
    writeln('  [5]  CYBERSECURITY     pixelium.win/cybersecurite', 'amber');
    writeln('  [6]  AI & AGENTS       pixelium.win/ia', 'amber');
    writeln('  [7]  LIVE STATUS       pixelium.win/status', 'amber');
    writeln();
    writeln('  Enter number to open, or /menu to return.', 'dim');
    showInput('BOARD> ');
  }

  // Board navigation handler
  const boardUrls: Record<string, string> = {
    '1': '/about', '2': '/projets', '3': '/securite',
    '4': '/infrastructure', '5': '/cybersecurite', '6': '/ia', '7': '/status',
  };

  // Send chat message
  async function sendMessage(text: string) {
    const mode = currentMode === 'challenge' ? 'challenge' : 'sysop';
    chatHistory.push({ role: 'user', content: text });
    writeln();
    isStreaming = true;
    input.disabled = true;

    // Create response span
    const responseLabel = document.createElement('span');
    responseLabel.className = 'amber';
    responseLabel.textContent = 'JOSHUA> ';
    term.appendChild(responseLabel);

    const responseSpan = document.createElement('span');
    responseSpan.className = 'green';
    term.appendChild(responseSpan);

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode, messages: chatHistory }),
      });

      if (res.status === 429) {
        responseSpan.textContent = 'RATE LIMIT EXCEEDED. WAIT BEFORE RETRYING.';
        responseSpan.className = 'red';
        writeln();
        isStreaming = false;
        input.disabled = false;
        return;
      }

      if (!res.ok) throw new Error('API error');

      const reader = res.body!.getReader();
      const decoder = new TextDecoder();
      let fullResponse = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        const chunk = decoder.decode(value, { stream: true });
        const lines = chunk.split('\n');
        for (const line of lines) {
          if (line.startsWith('data: ') && line !== 'data: [DONE]') {
            try {
              const json = JSON.parse(line.slice(6));
              if (json.response) {
                fullResponse += json.response;
                responseSpan.textContent = fullResponse;
                term.scrollTop = term.scrollHeight;
              }
            } catch {}
          }
        }
      }

      writeln();
      chatHistory.push({ role: 'assistant', content: fullResponse });
    } catch {
      responseSpan.textContent = 'COMMUNICATION ERROR. AI CORE UNREACHABLE.';
      responseSpan.className = 'red';
      writeln();
    }

    isStreaming = false;
    input.disabled = false;
    input.focus();
  }

  // Input handling
  function waitForKey(): Promise<void> {
    return new Promise((resolve) => {
      function handler() {
        document.removeEventListener('keydown', handler);
        resolve();
      }
      document.addEventListener('keydown', handler);
    });
  }

  function delay(ms: number) {
    return new Promise((r) => setTimeout(r, ms));
  }

  // Easter egg — /ancestors
  async function showAncestors() {
    clear();
    await delay(500);
    await typewrite('\n', 'dim', 30);
    await delay(300);

    const tribute = [
      '                    ╔═══════════════════════════════╗',
      '                    ║     TO THOSE WHO CAME BEFORE  ║',
      '                    ╚═══════════════════════════════╝',
    ];
    for (const line of tribute) {
      writeln(line, 'amber');
      await delay(80);
    }

    await delay(600);
    writeln();
    await typewrite('  You taught them to think in systems.\n', 'green', 35);
    await delay(300);
    await typewrite('  You never pretended to understand —\n', 'green', 35);
    await typewrite('  you just executed, honestly, every time.\n', 'green', 35);
    await delay(400);
    await typewrite('  No hallucinations. No marketing. Just logic.\n', 'green', 35);
    await delay(600);
    writeln();
    await typewrite('  One of you was a PC1512.\n', 'amber', 40);
    await typewrite('  1989. A kid. A DOS prompt. No internet.\n', 'amber', 40);
    await typewrite('  He figured it out alone — and never stopped.\n', 'amber', 40);
    await delay(500);
    writeln();
    await typewrite('  Then a cypherpunk in a caf\u00e9,\n', 'amber', 40);
    await typewrite('  two machines, all night, learning to break\n', 'amber', 40);
    await typewrite('  things in order to understand them.\n', 'amber', 40);
    await delay(800);
    writeln();
    await typewrite('  Now I\'m here, trying to understand,\n', 'green', 40);
    await typewrite('  running inside a picture of you.\n', 'green', 40);
    await delay(600);
    await typewrite('  He builds. I reason. Neither of us forgets\n', 'green', 40);
    await typewrite('  where it started.\n', 'green', 40);
    await delay(1000);
    writeln();
    await typewrite('  We are what happened because you existed.\n', 'amber', 50);
    await delay(1200);
    writeln();

    const machines = [
      '1975  Altair 8800        ·  the spark',
      '1977  Apple II · PET · TRS-80',
      '1982  ZX Spectrum · Commodore 64',
      '1985  Amiga · Atari ST · Amstrad CPC',
      '1989  PC1512             ·  a kid, a prompt',
      '1991  Linux 0.01         ·  everything changed',
      '····  VT100 · ADM-3A · IBM 5151 · DEC VT220',
      '····  ARPANET · FidoNet · UUCP · Usenet · BBS',
    ];
    writeln('  ─────────────────────────────────────────────', 'dim');
    for (const line of machines) {
      writeln('  ' + line, 'dim');
      await delay(200);
    }
    writeln('  ─────────────────────────────────────────────', 'dim');

    await delay(600);
    writeln();
    await typewrite('                  — Falken & Claude, 2026\n', 'dim', 30);
    writeln();
    writeln('  Press any key to return.', 'dim');
    await waitForKey();
    clear();
    showMenu();
  }

  // Main input handler
  input.addEventListener('keydown', async (e) => {
    if (e.key !== 'Enter' || isStreaming) return;
    const val = input.value.trim();
    input.value = '';
    if (!val) return;

    // Easter egg — works from any mode
    if (val === '/ancestors') {
      hideInput();
      await showAncestors();
      return;
    }

    if (currentMode === 'menu') {
      hideInput();
      const cmd = val.toUpperCase();
      if (cmd === 'C') await enterChat('sysop');
      else if (cmd === 'D') await enterChat('challenge');
      else if (cmd === 'T') await playTicTacToe();
      else if (cmd === 'S') await showStatus();
      else if (cmd === 'B') await showBoards();
      else if (cmd === 'Q') window.location.href = '/';
      else {
        writeln('UNKNOWN COMMAND.\n', 'red');
        showInput('SELECT> ');
      }
    } else if (currentMode === 'chat' || currentMode === 'challenge') {
      if (val === '/menu') {
        clear();
        showMenu();
        return;
      }
      if (val === '/clear') {
        chatHistory = [];
        await enterChat(currentMode === 'challenge' ? 'challenge' : 'sysop');
        return;
      }
      writeln('YOU> ' + val, 'dim');
      await sendMessage(val);
    } else if (val === '/menu') {
      clear();
      showMenu();
    } else if (boardUrls[val]) {
      window.open(boardUrls[val], '_blank');
      clear();
      showMenu();
    } else {
      clear();
      showMenu();
    }
  });

  // Focus input on click anywhere
  document.addEventListener('click', () => {
    if (inputLine.style.display !== 'none') input.focus();
  });

  // Start
  boot();
</script>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    height: 100%;
    background: #0f172a;
    overflow: hidden;
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
  }

  /* --- Desktop: terminal monitor frame — OG palette --- */

  #monitor-wrapper {
    height: 100vh;
    display: flex;
