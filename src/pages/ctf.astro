    transform: scale(1.05);
  }

  /* Feedback loop */
  .feedback-loop {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .loop-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }

  .loop-arrow {
    color: var(--color-accent);
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .loop-item > div {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .loop-offense {
