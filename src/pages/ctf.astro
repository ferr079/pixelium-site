            <a href="https://app.hackthebox.com/users/1161145" target="_blank" rel="noopener" aria-label="Hack The Box profile">
              <img src="https://www.hackthebox.com/badge/image/1161145" alt="Hack The Box badge for Ferr079" class="ctf-badge" loading="lazy" />
            </a>
            <a href="https://tryhackme.com/p/ferr0" target="_blank" rel="noopener" aria-label="TryHackMe profile">
              <img src="https://tryhackme-badges.s3.amazonaws.com/ferr0.png" alt="TryHackMe badge for ferr0" class="ctf-badge" loading="lazy" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTF Profiles -->
    <section class="layer">
      <div class="container">
        <div class="layer-header">
          <img src="https://cdn.simpleicons.org/hackthebox/9FEF00" alt="" class="tech-logo" loading="lazy" aria-hidden="true" onerror="this.style.display='none'" />
