---
import Base from '../layouts/Base.astro';
import StatsBar from '../components/StatsBar.astro';
import DynNum from '../components/DynNum.astro';

// HTB — fetch at build time
let htb = { rank: 'Hacker', ranking: 972, system_owns: 24, user_owns: 26, flags: 95 };
try {
  const htbRes = await fetch('https://labs.hackthebox.com/api/v4/user/profile/basic/1161145', {
    headers: { 'Authorization': `Bearer ${import.meta.env.HTB_API_TOKEN}` },
  });
  if (htbRes.ok) {
    const data = await htbRes.json();
    htb = { ...htb, rank: data.profile.rank, ranking: data.profile.ranking, system_owns: data.profile.system_owns, user_owns: data.profile.user_owns };
  }
  const actRes = await fetch('https://labs.hackthebox.com/api/v4/user/profile/activity/1161145', {
    headers: { 'Authorization': `Bearer ${import.meta.env.HTB_API_TOKEN}` },
  });
  if (actRes.ok) {
    const actData = await actRes.json();
    htb.flags = (actData.profile?.activity || []).length;
  }
} catch (_) {}
const htbFlags = htb.flags;

// Root-Me — fetch at build time
let rootme = { score: 765, position: 21847, validations: 63 };
try {
  const rmRes = await fetch(`https://api.www.root-me.org/auteurs/${import.meta.env.ROOTME_UID}`, {
    headers: { 'Cookie': `api_key=${import.meta.env.ROOTME_API_KEY}` },
  });
  if (rmRes.ok) {
    const data = await rmRes.json();
    rootme = { score: parseInt(data.score) || 765, position: data.position ?? 21847, validations: (data.validations || []).length || 63 };
  }
} catch (_) {}
---

<Base title="CTF — pixelium.win" description={`Capture The Flag profiles — HTB (${htb.rank} rank, #${htb.ranking}), TryHackMe (Top 15%), Root-Me (${rootme.score} pts). Verified offensive security training by Stéphane, documented by Claude.`}>
  <main>
    <section class="hero-mini">
      <div class="container">
        <p class="terminal-prompt">$ cat /var/log/flags/captured</p>
        <h1>Capture The Flag<span class="dot">.</span></h1>
        <p class="subtitle">Verified offensive security training on the platforms professionals use. Every technique learned here feeds back into the homelab's defenses.</p>
      </div>
    </section>

    <!-- Verified badges -->
    <section class="layer">
      <div class="container">
        <div class="layer-header">
          <h2>Verified badges</h2>
        </div>
        <div class="layer-content">
          <p>Independent, dynamically generated badges — pulled directly from HTB and THM servers. These are not screenshots — they update in real time as St&eacute;phane progresses.</p>
