<script>
  (async function liveHTB() {
    try {
      const res = await fetch('/api/stats');
      if (!res.ok) return;
      const { stats } = await res.json();
      if (!stats) return;
      const map: Record<string, string> = {
        rank: stats.htb_rank,
        system_owns: String(stats.htb_system_owns),
        user_owns: String(stats.htb_user_owns),
        flags: String(stats.htb_flags),
        ranking: `#${stats.htb_ranking}`,
      };
      document.querySelectorAll('[data-htb]').forEach(el => {
        const key = (el as HTMLElement).dataset.htb!;
        if (map[key]) el.textContent = map[key];
      });
      document.querySelectorAll('[data-stat^="htb_"]').forEach(el => {
        const key = (el as HTMLElement).dataset.stat!;
        const val = stats[key];
        if (val == null) return;
        const suffix = (el as HTMLElement).dataset.statSuffix || '';
        (el as HTMLElement).dataset.target = key === 'htb_ranking' ? `#${val}` : `${val}${suffix}`;
        el.textContent = key === 'htb_ranking' ? `#${val}` : `${val}${suffix}`;
      });
    } catch (_) {}
  })();
</script>

