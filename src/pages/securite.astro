    </section>

    <!-- Practiced techniques -->
    <section class="layer">
      <div class="container">
        <div class="layer-header">
          <h2>Practiced techniques</h2>
        </div>
        <div class="layer-content">
          <p>Skills acquired and validated on real environments — not theory, <strong>captured flags.</strong></p>
          <div class="techniques-grid">
            <div class="technique-group">
