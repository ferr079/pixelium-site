              <li>PentestAgent</li>
              <li>Docker Kali</li>
              <li>Ollama (RTX 3090)</li>
              <li>MCP</li>
            </ul>
            <span class="project-services">4 conteneurs, LLM local, 31 skills cybersec, 1 vrai finding dès le jour 1</span>
          </div>
        </div>
      </div>
    </section>

