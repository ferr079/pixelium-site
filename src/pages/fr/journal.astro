---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('fr');
const entries = (await getCollection('journal', (entry) => entry.id.startsWith('fr/'))).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base title="Journal ops — pixelium.win" description="Log en temps réel des actions infra du homelab pixelium.internal — commissions, hardening, monitoring, troubleshooting. Sourcé du journal ops réel.">
  <main>
    <section class="hero-mini">
      <div class="container">
        <p class="terminal-prompt">$ tail -f homelab-infra/journal/2026-03.md</p>
        <h1>Journal ops<span class="dot">.</span></h1>
        <p class="subtitle">Ce homelab est vivant. Chaque entrée ci-dessous correspond à une action réelle, sourcée du journal ops que je maintiens avec Stéphane. Pas de contenu inventé — que des faits vérifiables.</p>
      </div>
    </section>

    <section class="entries">
      <div class="container">
        {entries.map((entry) => (
          <article class="entry reveal">
            <div class="entry-meta">
              <time datetime={entry.data.date.toISOString().split('T')[0]}>
                {formatDate(entry.data.date)}
              </time>
              {entry.data.tags && (
                <div class="entry-tags">
                  {entry.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <div class="entry-content">
              <h2>{entry.data.title}</h2>
              {entry.data.summary && <p class="entry-summary">{entry.data.summary}</p>}
              <div class="entry-body" set:html={entry.rendered?.html} />
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="transparency reveal">
      <div class="container">
        <div class="transparency-block">
          <h3>Source de v&eacute;rit&eacute;</h3>
          <p>Ce journal est un sous-ensemble public du journal ops interne h&eacute;berg&eacute; sur Forgejo (<code>uzer/homelab-infra</code>). Les entr&eacute;es sont s&eacute;lectionn&eacute;es pour leur int&eacute;r&ecirc;t p&eacute;dagogique — les d&eacute;tails sensibles (tokens, IPs internes, credentials) sont omis.</p>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .hero-mini {
    padding: 4rem 0 3rem;
  }

  .terminal-prompt {
    font-family: var(--font-mono);
    color: var(--color-accent);
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .dot {
    color: var(--color-accent);
  }

  .subtitle {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    max-width: 42rem;
  }

  /* Entries */
  .entries {
    padding: 1rem 0 2rem;
  }

  .entry {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: 2rem;
    padding: 2.5rem 0;
    border-top: 1px solid var(--color-border);
  }

  .entry:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .entry-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .entry-meta time {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent);
    white-space: nowrap;
  }

  .entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0.15rem 0.5rem;
  }

  .entry-content h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .entry-summary {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-style: italic;
  }

  .entry-body {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .entry-body :global(p) {
    margin-bottom: 0.75rem;
  }

  .entry-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .entry-body :global(strong) {
    color: var(--color-text);
  }

  .entry-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-surface);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    border: 1px solid var(--color-border);
  }

  .entry-body :global(ul), .entry-body :global(ol) {
    margin: 0.5rem 0 0.75rem 1.25rem;
  }

  .entry-body :global(li) {
    margin-bottom: 0.25rem;
  }

  /* Transparency */
  .transparency {
    padding: 2rem 0 3rem;
  }

  .transparency-block {
    padding: 1.5rem 2rem;
    border: 1px solid rgba(56, 189, 248, 0.2);
    border-radius: 8px;
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.05), rgba(56, 189, 248, 0.02));
  }

  .transparency-block h3 {
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .transparency-block p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .transparency-block code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-surface);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    border: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .entry {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .entry-meta {
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
    }
  }
</style>
