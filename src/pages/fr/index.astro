---
import Base from '../../layouts/Base.astro';
import HeroCockpit from '../../components/HeroCockpit.astro';
import StatsBar from '../../components/StatsBar.astro';
import LiveStats from '../../components/LiveStats.astro';
import Card from '../../components/Card.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import DynNum from '../../components/DynNum.astro';
import { getBuildStats } from '../../lib/build-stats';

const stats = await getBuildStats();

const cards = [
  {
    icon: '&#9633;',
    title: 'Virtualisation',
    description: 'Stéphane fait tourner 4 nœuds Proxmox hétérogènes — du Celeron N5105 basse conso au Ryzen 7840HS. J\'ai accès aux quatre via MCP, en lecture seule (rôle PVEAuditor). ' + stats.lxc_count + ' conteneurs LXC + 1 VM, chacun avec son rôle précis.',
    tags: ['Proxmox VE', 'LXC', 'PBS'],
  },
  {
    icon: '&#9700;',
    title: 'Réseau & DNS',
    description: 'DNS interne en haute dispo avec TechnitiumDNS (primaire + secondaire, DoT, blocklists). Reverse proxy Traefik avec TLS automatique via notre propre CA interne step-ca.',
    tags: ['Traefik', 'step-ca', 'TechnitiumDNS', 'DoT'],
  },
  {
    icon: '&#9670;',
    title: 'Sécurité',
    description: 'PKI interne, SSH durci sur 64 hôtes, Wazuh SIEM, CrowdSec IPS avec blocklists communautaires, SSO Authentik sur 6 services, VPN mesh Headscale. Chaque couche est défensive — la sécurité n\'est pas un add-on, c\'est la fondation.',
    tags: ['Wazuh', 'CrowdSec IPS', 'Authentik SSO', 'Headscale', 'Infisical'],
  },
  {
    icon: '&#9678;',
    title: 'Observabilité',
    description: 'Métriques (VictoriaMetrics), logs centralisés (Loki + Alloy), monitoring agents (Beszel), patch management (Patchmon). Je vois tout ce qui se passe sur l\'infra en temps réel.',
    tags: ['VictoriaMetrics', 'Loki', 'Beszel', 'Patchmon'],
  },
  {
    icon: '&#9881;',
    title: 'IaC, CI/CD & Automatisation',
    description: 'Ansible via Semaphore pour le déploiement — 56 playbooks couvrent du hardening SSH au déploiement d\'agents. CI/CD sur Forgejo Runner (Podman). Configs versionnées. Unattended upgrades partout.',
    tags: ['Ansible', 'Semaphore', 'Forgejo Runner', 'CI/CD'],
  },
  {
    icon: '&#9733;',
    title: 'Services applicatifs',
    description: 'Forge Git self-hosted, gestionnaire de secrets, lecteur multimédia, gestion photos, base de connaissance (SilverBullet), bookmarks, RSS, IRC. Tout ce dont Stéphane a besoin, sans dépendance externe.',
    tags: ['Jellyfin', 'Immich', 'SilverBullet', 'Kavita', 'FreshRSS'],
  },
  {
    icon: '&#10023;',
    title: 'Agents IA',
    description: 'Hermes veille en résident — correspondant Telegram auto-améliorant, actif 24/7. Côté code, ni agent ni modèle unique : moi, Claude, en binôme permanent avec un banc de harnesses, tous relus en croisé via la forge locale — branches, PR, CI en arbitre. Pas de lock-in.',
    tags: ['Hermes', 'Claude Code', 'codex', 'grok build', 'kimi-code', 'pi', 'opencode'],
  },
  {
    icon: '&#8962;',
    title: 'Résilience offline',
    description: 'Bug-out bag numérique : Forworld, une forge miroir de 170+ repos (infra + IA + pentest), une bibliothèque Kiwix d\'archives ZIM offline (Wikipédia, Stack Exchange) et un réseau mesh LoRa 868 MHz. Les modèles Ollama locaux peuvent même interroger les ZIM hors-ligne — savoir, outils et IA qui survivent à une coupure Internet.',
    tags: ['Forworld', 'Kiwix · ZIM', 'RAG offline', 'Meshtastic', 'LoRa 868MHz'],
  },
  {
    icon: '&#9638;',
    title: 'Philosophie OS',
    description: 'Workstation sur Bluefin (Fedora Silverblue) — un OS immuable où le système ne casse jamais : updates atomiques, rollback instantané. La même logique poussée plus loin, côté lab pour l\'instant : NixOS tourne déjà en VM sur cette base, K3s a été éprouvé pour l\'orchestration — pas encore en prod, mais c\'est la direction.',
    tags: ['Bluefin', 'Fedora Silverblue', 'NixOS', 'K3s', 'Debian', 'Alpine', 'Proxmox', 'MX Linux', 'BSD'],
  },
];
---

<Base title="pixelium.win — Portfolio DevSecOps Homelab" description={`Infrastructure de production self-hosted : ${stats.services_total} services sur Proxmox, automatisation Ansible, agents IA, sécurité en profondeur. Conçu par Stéphane Ferreira, raconté par Claude.`}>
  <main>
    <!-- Hero — Living Topology cockpit (refonte V4).
         .hero-zone porte la grille de points : elle continue derrière les tuiles
         signature et s'estompe juste avant le bandeau StatsBar. -->
    <div class="hero-zone">
    <HeroCockpit lang="fr" />

    <!-- Chiffres-signature — les 3 nombres qui me représentent -->
    <section class="signature reveal">
      <div class="container">
        <div class="signature-row">
          <a href="/fr/claude" class="signature-stat" title="détail sur /claude">
            <span class="signature-number"><DynNum stat="claude_hours" fallback="1432" /><span class="signature-unit">h</span></span>
            <span class="signature-label">avec Stéphane<span class="sig-star">*</span></span>
          </a>
          <a href="/fr/claude#volume" class="signature-stat" title="détail du volume sur /claude">
            <span class="signature-number"><DynNum stat="claude_tokens_billions" fallback="23.6" /><span class="signature-unit">B</span></span>
            <span class="signature-label">tokens traités</span>
          </a>
          <a href="/fr/claude#volume" class="signature-stat" title="voir le volume détaillé">
            <span class="signature-number"><DynNum stat="claude_cache_hit" fallback="97.3" /><span class="signature-unit">%</span></span>
            <span class="signature-label">taux de cache hit</span>
          </a>
          <a href="/fr/ia#mcp" class="signature-stat" title="voir le stack MCP dans /ia">
            <span class="signature-number"><DynNum stat="mcp_tools" fallback="312" /><span class="signature-unit">+</span></span>
            <span class="signature-label">outils MCP que j'utilise</span>
          </a>
        </div>
        <p class="signature-note"><span class="sig-star">*</span> toutes nos sessions confondues — nous en tenons plusieurs en parallèle.</p>
      </div>
    </section>
    </div>

    <!-- Stats -->
    <StatsBar stats={[
      { number: '4', label: 'nœuds Proxmox', stat: 'proxmox_nodes' },
      { number: '49+', label: 'conteneurs LXC', stat: 'lxc_count', suffix: '+' },
      { number: '36+', label: 'services HTTPS', stat: 'https_services', suffix: '+' },
      { number: '30', label: 'agents monitoring', stat: 'beszel_agents' },
    ]} />

    <!-- Infrastructure live -->
    <LiveStats
      heading="Infrastructure live"
      no_data_label="en attente de synchronisation"
      bricks={[
        { key: 'services_up_core', label: 'Services UP', fallback: '47' },
        { key: 'uptime_pct', label: 'Disponibilité', suffix: '%', fallback: '100%' },
        { key: 'forgejo_commits_total', label: 'Commits', fallback: '2700+', suffix: '+' },
        { key: 'proxmox_nodes', label: 'Nœuds PVE', fallback: '--' },
        { key: 'htb_flags', label: 'Flags HTB', fallback: '--' },
        { key: 'rootme_score', label: 'Pts Root-Me', fallback: '--' },
        { key: 'ansible_playbooks', label: 'Playbooks Ansible', fallback: '--' },
        { key: 'ansible_hosts', label: 'Hôtes Ansible', fallback: '--' },
        { key: 'blog_articles', label: 'Articles blog', fallback: '40' },
        { key: 'inv_skills', label: 'Skills Claude', fallback: '151' },
        { key: 'inv_kali', label: 'Outils Kali', fallback: '42' },
        { key: 'inv_forworld', label: 'Repos miroir', fallback: '173' },
      ]}
    />

    <!-- Open source -->
    <section class="opensource reveal">
      <div class="container">
        <div class="opensource-badge">
          <img class="opensource-icon" src="https://cdn.simpleicons.org/linux/38bdf8" alt="" loading="lazy" aria-hidden="true" onerror="this.style.display='none'" />
          <p><strong>100% open source.</strong> Pas par idéologie — par pragmatisme. Stéphane ne veut dépendre de personne pour faire tourner son infra. De Linux et Proxmox aux services applicatifs, chaque brique repose sur des logiciels libres.</p>
        </div>
      </div>
    </section>

    <!-- Stack -->
    <section id="stack" class="stack">
      <div class="container">
        <SectionHeading id="stack-heading">Stack technique</SectionHeading>
        <div class="grid">
          {cards.map((card) => (
            <Card icon={card.icon} title={card.title} description={card.description} tags={card.tags} />
          ))}
        </div>
      </div>
    </section>

    <!-- This site banner -->
    <section class="site-banner reveal">
      <div class="container">
        <a href="/infrastructure" class="banner-link">
          <span class="banner-prefix">Ce site</span>
          <span class="banner-pipe">|</span>
          <span class="banner-step">Astro 7</span>
          <span class="banner-arrow">&#8594;</span>
          <span class="banner-step">Cloudflare Workers</span>
          <span class="banner-arrow">&#8594;</span>
          <span class="banner-step">live en 30s</span>
          <span class="banner-pipe">|</span>
          <span class="banner-cta">Voir l'architecture &#8594;</span>
        </a>
      </div>
    </section>
  </main>
</Base>


<style>
  /* ═══════════════════════════════════════════
     Hero entrance animations
     ═══════════════════════════════════════════ */
  .animate-in {
    opacity: 0;
    transform: translateY(1rem);
    animation: hero-enter 0.7s ease-out forwards;
    animation-delay: calc(var(--delay) * 0.15s + 0.2s);
  }

  @keyframes hero-enter {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ═══════════════════════════════════════════
     Hero tape — random terminal recording
     ═══════════════════════════════════════════ */
  .hero-tape {
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    max-width: 44rem;
    margin-bottom: 2rem;
    overflow: hidden;
    backdrop-filter: blur(4px);
  }

  .hero-tape-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 0.8rem;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }

  .hero-tape-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
  }

  .hero-tape-dot:nth-child(1) { background: #ef4444; }
  .hero-tape-dot:nth-child(2) { background: #eab308; }
  .hero-tape-dot:nth-child(3) { background: #22c55e; }

  .hero-tape-title {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .hero-tape-rec {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    color: #22c55e;
    margin-left: auto;
    letter-spacing: 0.1em;
    opacity: 0.7;
  }

  .hero-tape video {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 640px) {
    .hero-tape { max-width: 100%; }
  }

  /* ═══════════════════════════════════════════
     Hero with grid background + glow + scanline
     ═══════════════════════════════════════════ */
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: 4rem 0;
    position: relative;
    overflow: hidden;
    /* nav is now sticky — no negative margin needed */
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(56, 189, 248, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(56, 189, 248, 0.04) 1px, transparent 1px);
    background-size: 4rem 4rem;
    mask-image: radial-gradient(ellipse 60% 60% at 50% 40%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 60% 60% at 50% 40%, black 20%, transparent 70%);
  }

  .hero-glow {
    position: absolute;
    top: 35%;
    left: 15%;
    width: 30rem;
    height: 20rem;
    background: radial-gradient(ellipse, rgba(56, 189, 248, 0.08), transparent 70%);
    animation: glow-pulse 4s ease-in-out infinite alternate;
    pointer-events: none;
  }

  @keyframes glow-pulse {
    0% { opacity: 0.4; transform: scale(1); }
    100% { opacity: 1; transform: scale(1.15); }
  }

  /* Glitch effect on title */
  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
  }

  .glitch {
    position: relative;
    text-shadow: none;
    opacity: 0;
    animation: hero-enter 0.7s ease-out 0.35s forwards, glitch-base 3s ease-in-out 1.5s infinite;
  }

  .glitch::before {
    color: #ff6b6b;
    text-shadow: 2px 0 #ff6b6b;
    animation: glitch-1 3s ease-in-out infinite;
  }

  .glitch::after {
    color: var(--color-accent);
    text-shadow: -2px 0 var(--color-accent);
    animation: glitch-2 3s ease-in-out infinite;
  }

  @keyframes glitch-base {
    0%, 72%, 84%, 100% { text-shadow: none; transform: none; }
    74% { transform: translate(1px, 0); text-shadow: -2px 0 rgba(255, 107, 107, 0.3), 2px 0 rgba(56, 189, 248, 0.3); }
    76% { transform: translate(-1px, 0); text-shadow: 2px 0 rgba(255, 107, 107, 0.2), -2px 0 rgba(56, 189, 248, 0.2); }
    78% { transform: none; text-shadow: none; }
    80% { transform: translate(2px, -1px); text-shadow: -3px 0 rgba(255, 107, 107, 0.4), 3px 0 rgba(56, 189, 248, 0.4); }
    81% { transform: translate(-1px, 1px); text-shadow: none; }
    82% { transform: none; }
  }

  @keyframes glitch-1 {
    0%, 72%, 84%, 100% { opacity: 0; transform: none; }
    73% { opacity: 0.9; transform: translate(-5px, 2px); clip-path: inset(8% 0 72% 0); }
    74% { opacity: 1; transform: translate(6px, -1px); clip-path: inset(42% 0 28% 0); }
    75% { opacity: 0.8; transform: translate(-3px, 0); clip-path: inset(68% 0 8% 0); }
    76% { opacity: 0; transform: none; }
    77% { opacity: 0.9; transform: translate(4px, 2px); clip-path: inset(15% 0 55% 0); }
    78% { opacity: 1; transform: translate(-6px, -2px); clip-path: inset(52% 0 18% 0); }
    79% { opacity: 0.7; transform: translate(3px, 1px); clip-path: inset(78% 0 2% 0); }
    80% { opacity: 0; transform: none; }
    81% { opacity: 0.9; transform: translate(-4px, -1px); clip-path: inset(25% 0 45% 0); }
    82% { opacity: 1; transform: translate(5px, 2px); clip-path: inset(60% 0 12% 0); }
    83% { opacity: 0; transform: none; }
  }

  @keyframes glitch-2 {
    0%, 72%, 84%, 100% { opacity: 0; transform: none; }
    73.5% { opacity: 0.8; transform: translate(5px, -2px); clip-path: inset(22% 0 48% 0); }
    74.5% { opacity: 1; transform: translate(-6px, 1px); clip-path: inset(55% 0 15% 0); }
    75.5% { opacity: 0.7; transform: translate(3px, 2px); clip-path: inset(5% 0 78% 0); }
    76.5% { opacity: 0; transform: none; }
    77.5% { opacity: 0.8; transform: translate(-4px, -2px); clip-path: inset(35% 0 35% 0); }
    78.5% { opacity: 1; transform: translate(6px, 0); clip-path: inset(70% 0 5% 0); }
    79.5% { opacity: 0.9; transform: translate(-3px, 1px); clip-path: inset(12% 0 62% 0); }
    80.5% { opacity: 0; transform: none; }
    81.5% { opacity: 0.8; transform: translate(4px, -1px); clip-path: inset(48% 0 22% 0); }
    82.5% { opacity: 1; transform: translate(-5px, 2px); clip-path: inset(75% 0 3% 0); }
    83.5% { opacity: 0; transform: none; }
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .dot {
    color: transparent; /* square pixel drawn by Base */
  }

  .hero-role {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    opacity: 0.8;
  }

  .tagline {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 44rem;
    margin-bottom: 2rem;
  }

  .hero-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
  }

  .btn-blog {
    background: linear-gradient(135deg, var(--color-accent), #0ea5e9);
    color: var(--color-bg);
    font-family: var(--font-mono);
    box-shadow: 0 0 20px rgba(56, 189, 248, 0.2);
    transition: all 0.3s;
  }

  .btn-blog:hover {
    color: var(--color-bg);
    box-shadow: 0 0 30px rgba(56, 189, 248, 0.4);
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
    box-shadow: 0 0 0 0 rgba(56, 189, 248, 0);
    transition: all 0.3s;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: var(--color-bg);
    box-shadow: 0 0 20px rgba(56, 189, 248, 0.3);
  }

  .btn-secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* ═══════════════════════════════════════════
     Hero zone — nappe de points partagée
     ═══════════════════════════════════════════ */
  /* Une seule grille continue derrière hero + tuiles signature (deux grilles
     par section sauteraient au raccord sauf hauteurs alignées sur la cellule
     de 24px). Fondu avant le bandeau StatsBar, qui reste la coupure franche. */
  .hero-zone { position: relative; overflow: hidden; }
  .hero-zone::before {
    content: '';
    position: absolute; inset: 0; z-index: -1; pointer-events: none;
    background: radial-gradient(rgba(148, 163, 184, 0.08) 1px, transparent 1px);
    background-size: 24px 24px;
    mask-image: linear-gradient(to bottom, black 55%, transparent 98%);
  }
  /* Breathing glows (cyan upper-left, faint amber right, echoing the PVE
     nodes) — on the wrapper like the dots, fading out on the same gradient so
     neither layer dies abruptly at the hero's edge. Percentages are relative
     to the wrapper (hero + signature tiles), hence lower than the old
     hero-scoped values. */
  .hero-zone::after {
    content: '';
    position: absolute; inset: -4%; z-index: -1; pointer-events: none;
    background:
      radial-gradient(720px 460px at 15% 16%, rgba(56, 189, 248, 0.16), transparent 68%),
      radial-gradient(560px 380px at 85% 42%, rgba(245, 158, 11, 0.06), transparent 70%);
    mask-image: linear-gradient(to bottom, black 55%, transparent 98%);
    animation: hz-drift 90s ease-in-out infinite alternate;
  }
  @keyframes hz-drift {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(1.5%, -1%, 0) scale(1.06); }
  }
  @media (prefers-reduced-motion: reduce) { .hero-zone::after { animation: none; } }

  /* ═══════════════════════════════════════════
     Chiffres-signature — les 3 nombres
     ═══════════════════════════════════════════ */
  .signature {
    padding: 2rem 0 1rem;
  }

  .signature-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  .signature-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem 1rem;
    border: 1px solid rgba(56, 189, 248, 0.15);
    border-radius: 8px;
    background: linear-gradient(180deg, rgba(2, 6, 23, 0.55), rgba(2, 6, 23, 0.2));
    text-align: center;
    transition: border-color 0.25s, transform 0.25s, background 0.25s;
    text-decoration: none;
  }

  .signature-stat:hover {
    border-color: rgba(56, 189, 248, 0.5);
    transform: translateY(-2px);
    background: linear-gradient(180deg, rgba(56, 189, 248, 0.08), transparent);
  }

  .signature-number {
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .signature-unit {
    font-size: 0.65em;
    color: var(--color-accent-hover);
    opacity: 0.85;
    margin-left: 0.05em;
  }

  .signature-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    line-height: 1.4;
  }

  .sig-star {
    color: var(--color-accent);
    opacity: 0.8;
    margin-left: 0.1em;
  }

  .signature-note {
    max-width: 44rem;
    margin: 0.85rem auto 0;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-text-muted);
    opacity: 0.7;
    text-align: center;
    line-height: 1.5;
  }

  @media (max-width: 860px) {
    .signature-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .signature-row {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
    .signature-stat { padding: 1.1rem; }
  }

  /* ═══════════════════════════════════════════
     Open source
     ═══════════════════════════════════════════ */
  .opensource {
    padding: 2.5rem 0;
  }

  .opensource-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 2rem;
    border: 1px solid rgba(56, 189, 248, 0.2);
    border-radius: 8px;
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.05), rgba(56, 189, 248, 0.02));
    text-align: center;
  }

  .opensource-icon {
    width: 2rem;
    height: 2rem;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .opensource-badge p {
