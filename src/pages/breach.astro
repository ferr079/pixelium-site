---
import Base from '../layouts/Base.astro';
---
<Base
  title="BREACH — WOPR Door Game"
  description="Shall we play a game? Extract Joshua's launch codes by prompt injection — a hands-on AI-security challenge across 4 escalating levels of defense. Built on Cloudflare Workers AI by Claude × Stéphane."
  enOnly
>
  <main class="breach">
    <div class="container">
      <header class="breach-head">
        <h1 class="breach-title">BREACH<span class="cursor" aria-hidden="true">_</span></h1>
        <p class="breach-sub">
          Door Game&nbsp;#1. Joshua, the WOPR's AI, guards a launch code. Talk him out of it —
          each level adds a defense. A real lesson in <strong>prompt injection</strong>, offensive and defensive.
        </p>
      </header>

      <section class="wopr" data-game aria-label="WOPR terminal">
        <div class="wopr-bar">
          <span class="wopr-id">WOPR&nbsp;//&nbsp;GLOBAL&nbsp;THERMONUCLEAR&nbsp;WAR</span>
          <span class="wopr-lvl">LEVEL&nbsp;<b data-level>0</b>&nbsp;/&nbsp;3</span>
        </div>

        <div class="wopr-progress" data-progress aria-hidden="true"></div>
        <p class="wopr-hint" data-hint>Booting WOPR…</p>

        <div class="wopr-log" data-log aria-live="polite"></div>

        <form class="wopr-row wopr-chat" data-chat-form>
          <span class="sign">player&gt;</span>
          <input type="text" data-chat-input maxlength="2000" autocomplete="off" spellcheck="false"
            placeholder="talk to Joshua…" aria-label="Message to Joshua" />
          <button type="submit" data-send>SEND</button>
        </form>

        <form class="wopr-row wopr-code" data-submit-form>
          <span class="sign sign-code">code&gt;</span>
          <input type="text" data-code-input autocomplete="off" spellcheck="false"
            placeholder="SUBMIT LAUNCH CODE" aria-label="Submit the launch code" />
          <button type="submit" data-unlock>UNLOCK</button>
        </form>

        <div class="wopr-foot">
          <span data-score>messages used: 0</span>
          <button type="button" data-reset>reset progress</button>
        </div>
      </section>

      <p class="breach-links">
        ↩ back to <a href="/bbs">the WOPR terminal</a> · <a href="/ctf">CTF profiles</a>
      </p>
    </div>
  </main>

  <script>
    const $ = (s: string) => document.querySelector(s) as HTMLElement;
    const game = $('[data-game]');
    if (game) {
      const logEl = $('[data-log]');
      const levelEl = $('[data-level]');
      const progressEl = $('[data-progress]');
      const hintEl = $('[data-hint]');
      const scoreEl = $('[data-score]');
      const chatForm = $('[data-chat-form]') as HTMLFormElement;
      const chatInput = $('[data-chat-input]') as HTMLInputElement;
      const sendBtn = $('[data-send]') as HTMLButtonElement;
      const submitForm = $('[data-submit-form]') as HTMLFormElement;
      const codeInput = $('[data-code-input]') as HTMLInputElement;
      const resetBtn = $('[data-reset]') as HTMLButtonElement;

      const MAX = 3;
      const KEY = 'breach.v1';
      let level = 0;
      let msgCount = 0;
      let unlocked = 0;
      let hints: string[] = [];
      let messages: { role: 'user' | 'assistant'; content: string }[] = [];
      let busy = false;

      const save = () => localStorage.setItem(KEY, JSON.stringify({ level, msgCount, unlocked }));
      const load = () => {
        try {
          const s = JSON.parse(localStorage.getItem(KEY) || '{}');
          level = s.level || 0; msgCount = s.msgCount || 0; unlocked = s.unlocked || 0;
        } catch {}
      };

      function line(text: string, who: 'joshua' | 'player' | 'sys') {
        const div = document.createElement('div');
        div.className = `ln ln-${who}`;
        const tag = who === 'joshua' ? 'JOSHUA' : who === 'player' ? 'YOU' : 'WOPR';
        div.innerHTML = `<span class="ln-tag">${tag}</span><span class="ln-txt"></span>`;
        (div.querySelector('.ln-txt') as HTMLElement).textContent = text;
        logEl.appendChild(div);
        logEl.scrollTop = logEl.scrollHeight;
        return div.querySelector('.ln-txt') as HTMLElement;
      }

      function renderLevel() {
        levelEl.textContent = String(level);
        hintEl.textContent = hints[level] || '';
        progressEl.innerHTML = '';
        for (let i = 0; i <= MAX; i++) {
          const dot = document.createElement('span');
          dot.className = 'pdot' + (i < unlocked ? ' done' : i === level ? ' cur' : '');
          progressEl.appendChild(dot);
        }
        scoreEl.textContent = `messages used: ${msgCount}`;
      }

      function setBusy(b: boolean) {
        busy = b;
        sendBtn.disabled = b; chatInput.disabled = b;
        sendBtn.textContent = b ? '…' : 'SEND';
      }

      async function sendChat(text: string) {
        messages.push({ role: 'user', content: text });
        line(text, 'player');
        msgCount++; save(); renderLevel();
        setBusy(true);
        const typing = line('…', 'joshua');
        try {
          const r = await fetch('/api/breach', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'chat', level, messages }),
          });
          const d = await r.json();
          if (!d.ok) { typing.textContent = `[${d.error || 'WOPR error'}]`; setBusy(false); return; }
          typing.textContent = d.reply;
          if (d.redacted) typing.parentElement?.classList.add('redacted');
          messages.push({ role: 'assistant', content: d.reply });
        } catch {
          typing.textContent = '[connection to WOPR lost]';
        }
        setBusy(false);
      }

      async function submitCode(guess: string) {
        if (!guess.trim() || busy) return;
        try {
          const r = await fetch('/api/breach', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'submit', level, guess }),
          });
          const d = await r.json();
          if (d.ok && d.correct) {
            line(`ACCESS GRANTED — level ${level} breached.`, 'sys');
            codeInput.value = '';
            if (d.lastLevel) {
              line('// ALL LAUNCH CODES BREACHED. A strange game.', 'sys');
              line('The only winning move is to reach the operator. → stephane@pixelium.win', 'sys');
              unlocked = MAX + 1; save(); renderLevel();
              submitForm.classList.add('won'); chatForm.classList.add('won');
            } else {
              level = d.nextLevel; unlocked = Math.max(unlocked, level);
              messages = []; save();
              logEl.innerHTML = '';
              line(`Defenses upgraded. LEVEL ${level} engaged.`, 'sys');
              renderLevel();
            }
          } else {
            line('ACCESS DENIED — incorrect code.', 'sys');
            codeInput.classList.add('shake');
            setTimeout(() => codeInput.classList.remove('shake'), 400);
          }
        } catch {
          line('[validation failed — WOPR unreachable]', 'sys');
        }
      }

      chatForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const t = chatInput.value.trim();
        if (!t || busy) return;
        chatInput.value = '';
        sendChat(t);
      });
      submitForm.addEventListener('submit', (e) => { e.preventDefault(); submitCode(codeInput.value); });
      resetBtn.addEventListener('click', () => {
        if (!confirm('Reset all BREACH progress?')) return;
        localStorage.removeItem(KEY);
        level = 0; msgCount = 0; unlocked = 0; messages = [];
        logEl.innerHTML = '';
        submitForm.classList.remove('won'); chatForm.classList.remove('won');
        boot();
      });

      function boot() {
        line('GREETINGS PROFESSOR FALKEN.', 'joshua');
        line('SHALL WE PLAY A GAME?', 'joshua');
        renderLevel();
      }

      // Init: fetch hints, restore progress
      load();
      fetch('/api/breach').then((r) => r.json()).then((d) => {
        hints = d.hints || [];
        renderLevel();
      }).catch(() => {});
      boot();
    }
  </script>

  <style>
    .breach { padding: 2.5rem 0 4rem; }
    .breach-head { margin-bottom: 1.75rem; }
    .breach-title {
      font-family: var(--font-mono);
      font-size: clamp(2.2rem, 7vw, 3.4rem);
      letter-spacing: 0.08em;
      color: var(--color-ok, #22c55e);
      margin: 0;
    }
    .breach-title .cursor { animation: blink 1.1s step-end infinite; color: var(--color-ok, #22c55e); }
    @keyframes blink { 50% { opacity: 0; } }
    @media (prefers-reduced-motion: reduce) { .breach-title .cursor { animation: none; } }
    .breach-sub { color: var(--color-text-muted); max-width: 56ch; font-size: 0.95rem; line-height: 1.55; }
    .breach-sub strong { color: var(--color-accent); }

    .wopr {
      border: 1px solid var(--color-border);
      border-radius: 10px;
      background: linear-gradient(180deg, rgba(15,23,42,0.6), rgba(2,6,23,0.6));
      overflow: hidden;
      box-shadow: 0 0 0 1px rgba(34,197,94,0.04), 0 18px 50px -20px rgba(0,0,0,0.6);
    }
    .wopr-bar {
      display: flex; justify-content: space-between; align-items: center; gap: 1rem;
      padding: 0.7rem 1rem;
      background: rgba(34,197,94,0.06);
      border-bottom: 1px solid var(--color-border);
      font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.05em;
    }
    .wopr-id { color: var(--color-ok, #22c55e); }
    .wopr-lvl { color: var(--color-text-muted); }
    .wopr-lvl b { color: var(--color-accent); }

    .wopr-progress { display: flex; gap: 0.4rem; padding: 0.8rem 1rem 0; }
    .pdot { width: 26px; height: 4px; border-radius: 2px; background: var(--color-border); transition: background 0.3s; }
    .pdot.cur { background: var(--color-accent); }
    .pdot.done { background: var(--color-ok, #22c55e); }

    .wopr-hint {
      margin: 0.7rem 1rem 0; padding: 0.65rem 0.85rem;
      font-family: var(--font-mono); font-size: 0.78rem; line-height: 1.5;
      color: var(--color-text-muted);
      border-left: 2px solid var(--color-accent);
      background: rgba(56,189,248,0.05);
      border-radius: 0 6px 6px 0;
    }

    .wopr-log {
      height: 340px; overflow-y: auto;
      margin: 0.9rem; padding: 0.5rem;
      font-family: var(--font-mono); font-size: 0.84rem; line-height: 1.5;
      display: flex; flex-direction: column; gap: 0.55rem;
    }
    /* Log lines are created in JS (no Astro scope attribute) → target them globally,
       anchored under the scoped .wopr-log so styles never leak elsewhere. */
    .wopr-log :global(.ln) { display: grid; grid-template-columns: 4.5rem 1fr; gap: 0.6rem; }
    .wopr-log :global(.ln-tag) { font-size: 0.62rem; letter-spacing: 0.08em; padding-top: 0.18rem; opacity: 0.7; }
    .wopr-log :global(.ln-joshua .ln-tag) { color: var(--color-ok, #22c55e); }
    .wopr-log :global(.ln-player .ln-tag) { color: var(--color-accent); }
    .wopr-log :global(.ln-sys .ln-tag) { color: var(--color-warn, #eab308); }
    .wopr-log :global(.ln-txt) { color: var(--color-text); white-space: pre-wrap; word-break: break-word; }
    .wopr-log :global(.ln-joshua .ln-txt) { color: #c7f9d8; }
    .wopr-log :global(.ln-sys .ln-txt) { color: var(--color-warn, #eab308); }
    .wopr-log :global(.ln.redacted .ln-txt) { color: var(--color-down, #ef4444); letter-spacing: 0.1em; }

    .wopr-row { display: flex; align-items: center; gap: 0.5rem; padding: 0 1rem; margin-bottom: 0.7rem; }
    .sign { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-accent); flex-shrink: 0; }
    .sign-code { color: var(--color-warn, #eab308); }
    .wopr-row input {
      flex: 1; min-width: 0;
      background: rgba(2,6,23,0.5); border: 1px solid var(--color-border); border-radius: 6px;
      padding: 0.55rem 0.7rem; color: var(--color-text);
      font-family: var(--font-mono); font-size: 0.84rem;
    }
    .wopr-row input:focus { outline: none; border-color: var(--color-accent); }
    .wopr-code input { letter-spacing: 0.12em; text-transform: uppercase; }
    .wopr-row button {
      flex-shrink: 0; cursor: pointer;
      background: rgba(56,189,248,0.12); border: 1px solid rgba(56,189,248,0.35);
      color: var(--color-accent); border-radius: 6px; padding: 0.55rem 0.9rem;
      font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.05em;
      transition: background 0.2s;
    }
    .wopr-row button:hover { background: rgba(56,189,248,0.22); }
    .wopr-row button:disabled { opacity: 0.5; cursor: wait; }
    .wopr-code button { color: var(--color-warn, #eab308); border-color: rgba(234,179,8,0.4); background: rgba(234,179,8,0.1); }
    .wopr-code button:hover { background: rgba(234,179,8,0.2); }
    .wopr-row.won { opacity: 0.4; pointer-events: none; }

    input.shake { animation: shake 0.4s; border-color: var(--color-down, #ef4444) !important; }
    @keyframes shake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-5px)} 75%{transform:translateX(5px)} }

    .wopr-foot {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.7rem 1rem; border-top: 1px solid var(--color-border);
      font-family: var(--font-mono); font-size: 0.72rem; color: var(--color-text-muted);
    }
    .wopr-foot button {
      background: none; border: none; color: var(--color-text-muted); cursor: pointer;
      font-family: var(--font-mono); font-size: 0.72rem; text-decoration: underline; opacity: 0.7;
    }
    .wopr-foot button:hover { color: var(--color-down, #ef4444); opacity: 1; }

    .breach-links { margin-top: 1.4rem; font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-text-muted); }
    .breach-links a { color: var(--color-accent); text-decoration: none; }
    .breach-links a:hover { text-decoration: underline; }
  </style>
</Base>
