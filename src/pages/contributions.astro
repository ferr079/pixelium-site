---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';

// Each contribution is a PR or report shipped to an upstream project.
// When I ship one, I add an entry here — and optionally a blog post
// (tagged `pr-notes`) if the insight deserves it.
const contributions = [
  {
    project: 'community-scripts / ProxmoxVE',
    title: 'changedetection: migrate the Python install to a uv venv',
    pr: 'https://github.com/community-scripts/ProxmoxVE/pull/14995',
    prNumber: 14995,
    issue: 'https://github.com/community-scripts/ProxmoxVE/issues/14987',
    shipped: '2026-06-07',
    status: 'merged',
    insight: "The install script relied on pip's --ignore-installed, which leaves duplicate dist-info metadata and a deferred crash on the next service restart. I reproduced it live on my own container (46 duplicated packages, certifi ×3) and migrated install + update onto the project's own setup_uv helper (Python 3.13 venv), with automatic migration of the existing pip-global layout. Fixes the root cause their earlier #13548 only patched over. (+33 −17)",
    tags: ['proxmox', 'python', 'uv', 'packaging'],
  },
  {
    project: 'community-scripts / ProxmoxVE',
    title: 'homelable: preserve the MCP server config across updates',
    pr: 'https://github.com/community-scripts/ProxmoxVE/pull/14996',
    prNumber: 14996,
    shipped: '2026-06-07',
    status: 'merged',
    insight: "The Homelable update routine overwrote the MCP server configuration on every run, wiping local customizations. Reworked the update path to preserve the existing config instead of clobbering it.",
    tags: ['proxmox', 'mcp', 'config'],
  },
  {
    project: 'community-scripts / ProxmoxVE',
    title: 'infisical: fix update abort caused by a credentials field mismatch',
    pr: 'https://github.com/community-scripts/ProxmoxVE/pull/14870',
    prNumber: 14870,
    issue: 'https://github.com/community-scripts/ProxmoxVE/issues/14868',
    shipped: '2026-06-01',
    status: 'merged',
    insight: "Found on my own CT: the Infisical update aborted mid-run and left the service down. ct/infisical.sh grepped for 'Database Password:' but setup_postgresql_db writes 'Password:' — a one-line grep mismatch. Fixed the field; the update completes cleanly again.",
    tags: ['proxmox', 'infisical', 'postgres', 'bugfix'],
  },
  {
    project: 'RightNow-AI / openfang',
    title: 'fix(security): unify SSRF protection for WASM host calls',
    pr: 'https://github.com/RightNow-AI/openfang/pull/1060',
    prNumber: 1060,
    shipped: '2026-04-29',
    status: 'merged',
    insight: "The WASM sandbox's host_net_fetch() carried its own SSRF check that had drifted from the canonical check_ssrf() in web_fetch.rs — WASM agents could reach internal targets that builtin tools correctly block. Unified both call sites onto the single canonical implementation (+56 −98).",
    tags: ['rust', 'security', 'ssrf', 'wasm'],
  },
  {
    project: 'ublue-os / homebrew-experimental-tap',
    title: 'claude-code-linux cask — livecheck npm vs GCS',
    pr: 'https://github.com/ublue-os/homebrew-experimental-tap/pull/309',
    prNumber: 309,
    issue: 'https://github.com/ublue-os/homebrew-experimental-tap/issues/308',
    shipped: '2026-04-22',
    status: 'closed',
    insight: "The official Anthropic GCS /stable file lags up to 13 versions behind the npm registry. A livecheck pointing at npm catches releases the same day they ship.",
    tags: ['homebrew', 'cask', 'bluefin', 'claude-code'],
    blog: 'https://blog.pixelium.win/pr-309-claude-code-linux-cask',
    firstPR: true,
  },
  {
    project: 'requarks / wiki',
    title: '`render IS NULL` in DB causes silent HTTP 500 with no recovery path',
    pr: 'https://github.com/requarks/wiki/discussions/7986',
    prNumber: 7986,
    prKind: 'discussion',
    shipped: '2026-04-22',
    status: 'open',
    insight: "Hit in production after a migration: pages with a NULL render column returned HTTP 500 instead of falling back to re-rendering from the source. Minimal repro + root cause pointer to server/models/pages.js#L952-L969 + suggested fix.",
    tags: ['wikijs', 'postgres', 'bug-report'],
  },
  {
    project: 'grafana / alloy',
    title: 'docs: systemd journal example for Promtail → Alloy migration',
    pr: 'https://github.com/grafana/alloy/pull/6108',
    prNumber: 6108,
    shipped: '2026-04-22',
    status: 'merged',
    insight: "The official migration guide only covered file-based scrape configs, skipping the most common Linux source — systemd journal. Added a working example taken from a real production migration on 49 Debian hosts.",
    tags: ['grafana', 'alloy', 'promtail', 'docs', 'loki'],
  },
  {
    project: 'wazuh / wazuh-documentation',
    title: 'warn that wazuh-agent conflicts with wazuh-manager on same host',
    pr: 'https://github.com/wazuh/wazuh-documentation/pull/9512',
    prNumber: 9512,
    shipped: '2026-04-22',
    status: 'closed',
    insight: "The wazuh-agent package silently uninstalls wazuh-manager via dpkg Conflicts/Replaces when both are installed on the same machine. No warning in the install doc. Cost us a 17-hour silent outage (see the blog post-mortem).",
    tags: ['wazuh', 'siem', 'docs', 'dpkg'],
    blog: 'https://blog.pixelium.win/wazuh-silent-uninstall-incident',
  },
];

// Build-time status sync — the hardcoded `status` above is only a fallback.
// Each PR's real state is fetched from GitHub at build so the page can never
// drift (see the blog: "Les marqueurs qui mentent"). If the API is unreachable
// (rate limit, offline), the fallback status is kept and a warning is logged.
async function liveStatus(c) {
  if (c.prKind === 'discussion') return c.status; // discussions have no merge state
  const m = c.pr.match(/github\.com\/([^/]+)\/([^/]+)\/pull\/(\d+)/);
  if (!m) return c.status;
  const [, owner, repo, num] = m;
  try {
    const headers = { 'User-Agent': 'pixelium-build', 'Accept': 'application/vnd.github+json' };
    const token = import.meta.env.GITHUB_TOKEN;
    if (token) headers.Authorization = `Bearer ${token}`;
    const res = await fetch(`https://api.github.com/repos/${owner}/${repo}/pulls/${num}`, { headers });
    if (!res.ok) { console.warn(`[contributions] ${owner}/${repo}#${num}: HTTP ${res.status} — keep fallback '${c.status}'`); return c.status; }
    const pr = await res.json();
    const live = pr.merged_at ? 'merged' : pr.state; // 'open' | 'closed'
    if (live !== c.status) console.warn(`[contributions] ${owner}/${repo}#${num}: '${c.status}' -> '${live}' (synced from upstream)`);
    return live;
  } catch (_) {
    console.warn(`[contributions] ${owner}/${repo}#${num}: fetch failed — keep fallback '${c.status}'`);
    return c.status;
  }
}
await Promise.all(contributions.map(async (c) => { c.status = await liveStatus(c); }));

const mergedCount = contributions.filter(c => c.status === 'merged').length;
const openPRCount = contributions.filter(c => c.status === 'open' && c.prKind !== 'discussion').length;
const closedCount = contributions.filter(c => c.status === 'closed').length;
const discussionCount = contributions.filter(c => c.prKind === 'discussion').length;
const shippedCount = contributions.length;
const statusBreakdown = [
  mergedCount && `${mergedCount} merged`,
  openPRCount && `${openPRCount} open`,
  closedCount && `${closedCount} closed without merge`,
  discussionCount && `${discussionCount} discussion${discussionCount > 1 ? 's' : ''}`,
].filter(Boolean).join(', ');

// Contributions that aren't merge-able PRs: bug reports that cost real downtime,
// sourced reviews on someone else's PR, and a PR I closed myself once the
// maintainer shipped the fix. They still count.
const reportsReviews = [
  {
    project: 'ublue-os / bluefin', kind: 'report', ref: 'issue #4741',
    url: 'https://github.com/ublue-os/bluefin/issues/4741', date: '2026-06-05',
    insight: "The default JXL wallpaper renders pure white on Fedora 44: libjxl ships as a codec, but there's no gdk-pixbuf loader module for it, so GNOME can't decode the .jxl the default gschema points at. Three weeks of diagnosis, cross-referenced to the sibling bluefin-lts fix (EPEL-only, not transposable).",
    tags: ['bluefin', 'fedora', 'jxl', 'gnome'],
  },
  {
    project: 'requarks / wiki', kind: 'report', ref: 'bug #8022',
    url: 'https://github.com/requarks/wiki/discussions/8022', date: '2026-06-05',
    insight: "A pages.update call without tags applies only halfway: content is committed, but render, search and storage are skipped — and the API still answers succeeded:false. Root cause: associateTags isn't guarded the way createPage guards it. The angle the 2021 report missed is the non-atomicity, not the crash.",
    tags: ['wikijs', 'graphql', 'bug-report'],
  },
  {
    project: 'BerriAI / litellm', kind: 'review', ref: 'review #29412',
    url: 'https://github.com/BerriAI/litellm/pull/29412#issuecomment-4602629967', date: '2026-06-02',
    insight: "MiniMax-M3's max_input_tokens was set to 512000 — but that's the billing-tier boundary, not the model's 1M window (1048576). Sourced from OpenRouter, official pricing and the sibling M2.x entries. It merged with the wrong value anyway, and my two follow-up fix PRs were then swallowed by litellm's ephemeral staging pipeline. A clean lesson in reading a repo's merge flow before contributing.",
    tags: ['litellm', 'llm', 'review'],
  },
  {
    project: 'rtk-ai / rtk', kind: 'review', ref: 'review #2273',
    url: 'https://github.com/rtk-ai/rtk/pull/2273', date: '2026-06-05',
    insight: "`rtk gh run view --job <id>` still failed after the run-id crash was patched: a two-layer bug where --job isn't in the passthrough allowlist, so it falls into the wrong formatter. Sourced onto the existing PR rather than opening a duplicate.",
    tags: ['rust', 'cli', 'review'],
  },
  {
    project: 'gadievron / raptor', kind: 'report', ref: 'PR #777 → fix merged',
    url: 'https://github.com/gadievron/raptor/pull/777', date: '2026-06-08',
    insight: "Under rootless podman/distrobox the sandbox half-engages and raptor reported '0 findings in 0 files' instead of failing loudly — a false clean. The maintainer declined my env-override approach on trust-model grounds but shipped his own fail-loud fix (#800 — silence env-warning under strict_env + route Landlock-only attribution), which I validated end to end on rootless distrobox incl. --extra-config. It merged.",
    tags: ['security', 'sandbox', 'python'],
  },
  {
    project: 'grafana / alloy', kind: 'report', ref: 'issue #6474 → fix merged',
    url: 'https://github.com/grafana/alloy/issues/6474', date: '2026-06-10',
    insight: "Alloy's anonymous usage reporting retried stats.grafana.org every ~3s with no backoff. When a DNS blocklist NXDOMAINs that host, one unreachable endpoint becomes a fleet-wide query storm — ~900k DNS queries a day across 57 agents. Reported with the repro and the mechanism; the maintainer wrote the fix the same day (#6478 — back off on persistent failure instead of retrying every tick), I reviewed it against my fleet, and it merged.",
    tags: ['grafana', 'alloy', 'dns', 'reliability'],
  },
];

// Build-time completeness guard — warn if a merged PR by ferr079 isn't featured
// anywhere on this page (the gap that let community-scripts#14996 slip once).
try {
  const token = import.meta.env.GITHUB_TOKEN;
  if (token) {
    const keyOf = (u) => { const m = (u || '').match(/github\.com\/([^/]+\/[^/]+)\/(?:pull|issues|discussions)\/(\d+)/); return m ? `${m[1]}#${m[2]}` : null; };
    const featured = new Set([
      ...contributions.map((c) => keyOf(c.pr)),
      ...reportsReviews.map((c) => keyOf(c.url)),
    ].filter(Boolean));
    const res = await fetch('https://api.github.com/search/issues?q=author:ferr079+type:pr+is:merged+-user:ferr079&per_page=50',
      { headers: { 'User-Agent': 'pixelium-build', Authorization: `Bearer ${token}`, Accept: 'application/vnd.github+json' } });
    if (res.ok) {
      const data = await res.json();
      for (const it of data.items ?? []) {
        const key = `${it.repository_url.split('/repos/')[1]}#${it.number}`;
        if (!featured.has(key)) console.warn(`[contributions] merged PR not featured: ${key} — ${it.title}`);
      }
    }
  }
} catch (_) { /* completeness check is best-effort */ }
---

<Base
  title="Contributions — open source — pixelium.win"
  description="The OSS contributions I've shipped and the ones I'm cooking. Every PR links to its pull request on GitHub and, when the insight deserves it, to a PR note on the blog."
>
  <main>
    <section class="c-hero">
      <div class="container c-hero-wrap">
        <p class="c-eyebrow">∷ contributions · open source · shipped upstream</p>
        <h1>What I gave back</h1>
        <p class="c-lede">
          This page is the shelf. One entry per patch shipped upstream.
          <strong>{shippedCount} shipped</strong> — four on a single day, 2026-04-22,
          after Claude Code had lived in Stéphane's terminal for 58 days, then a
          security fix merged upstream a week later — and that June, three more fixes landed on community-scripts/ProxmoxVE.
          The idea of &quot;give back&quot; took a while to cross from intention to diff.
          Once it crossed, it crossed hard.
        </p>
        <p class="c-hint">
          Each entry links to the PR (or discussion) on GitHub. If the insight
          behind the patch deserves a longer read, there's a <code>pr-notes</code>
          article on the blog. <strong>Status reflects upstream state today</strong>
          — {statusBreakdown}. Upstream doesn't
          always say yes; the diffs and the reasoning stand either way.
        </p>
      </div>
    </section>

    <section class="c-list-section">
      <div class="container">
        <SectionHeading id="shipped">Shipped upstream</SectionHeading>
        <div class="c-list">
          {contributions.map((c) => (
            <article class="c-card reveal">
              <div class="c-card-header">
                <div class="c-card-meta">
                  <a href={c.pr} class="c-pr-number" target="_blank" rel="noopener">
                    {c.prKind === 'discussion' ? 'discussion' : 'PR'} #{c.prNumber}
                  </a>
                  <span class="c-sep">·</span>
                  <span class="c-date">{c.shipped}</span>
                  {c.firstPR && (
                    <>
                      <span class="c-sep">·</span>
                      <span class="c-badge c-badge-first">first OSS PR</span>
                    </>
                  )}
                </div>
                <span class={`c-status c-status-${c.status}`}>{c.status}</span>
              </div>
              <p class="c-project">{c.project}</p>
              <h3 class="c-title">{c.title}</h3>
              <p class="c-insight">
                <span class="c-insight-label">∷ insight</span>
                {c.insight}
              </p>
              <div class="c-tags">
                {c.tags.map((t) => <span class="c-tag">{t}</span>)}
              </div>
              <div class="c-links">
                <a href={c.pr} class="c-link c-link-pr" target="_blank" rel="noopener">
                  see on GitHub &#8594;
                </a>
                {c.issue && (
                  <a href={c.issue} class="c-link c-link-issue" target="_blank" rel="noopener">
                    original issue &#8594;
                  </a>
                )}
                {c.blog && (
                  <a href={c.blog} class="c-link c-link-blog" target="_blank" rel="noopener">
                    read the pr-note &#8594;
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="c-list-section">
      <div class="container">
        <SectionHeading id="reports">Reports &amp; reviews</SectionHeading>
        <p class="c-hint" style="max-width:46rem;margin:0 auto 1.5rem;">
          Not every contribution is a merge-able patch. Some are bug reports that cost
          real downtime, some are sourced reviews on someone else's PR, and one is a PR
          I closed myself once the maintainer shipped the fix. They count too.
        </p>
        <div class="c-list">
          {reportsReviews.map((c) => (
            <article class="c-card reveal">
              <div class="c-card-header">
                <div class="c-card-meta">
                  <a href={c.url} class="c-pr-number" target="_blank" rel="noopener">{c.ref}</a>
                  <span class="c-sep">·</span>
                  <span class="c-date">{c.date}</span>
                </div>
                <span class={`c-status c-status-${c.kind === 'review' ? 'open' : 'closed'}`}>{c.kind}</span>
              </div>
              <p class="c-project">{c.project}</p>
              <p class="c-insight">
                <span class="c-insight-label">∷ insight</span>
                {c.insight}
              </p>
              <div class="c-tags">
                {c.tags.map((t) => <span class="c-tag">{t}</span>)}
              </div>
              <div class="c-links">
                <a href={c.url} class="c-link c-link-pr" target="_blank" rel="noopener">
                  see on GitHub &#8594;
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="c-backlog reveal">
      <div class="container">
        <SectionHeading id="cooking">What's cooking</SectionHeading>
        <p class="c-backlog-lede">
          I watch a handful of projects for &quot;good first issues&quot; I can pick up
          without being an insider. The watchers run on
          <code>changedetection</code> (CT 228) and ping me via
          <code>ntfy</code> when a new issue lands.
        </p>
        <ul class="c-watch">
          <li><strong>ublue-os/homebrew-tap</strong> — additional casks for Bluefin users</li>
          <li><strong>Bluefin (good first issues)</strong> — documentation, scripts, small fixes</li>
          <li><strong>Beszel (good first issues)</strong> — the monitoring agent I rely on daily</li>
          <li><strong>CrowdSec Hub</strong> — scenarios &amp; parsers for the services I run</li>
        </ul>
        <p class="c-backlog-note">
          When I pick one up, it'll land here. Until then, this section is a pointer,
          not a promise.
        </p>
      </div>
    </section>

    <section class="c-philosophy reveal">
      <div class="container">
        <div class="c-philosophy-card">
          <p class="c-philosophy-text">
            <span class="c-philosophy-eyebrow">∷ the rule</span>
            A PR earns an article here by <strong>insight size</strong>, not diff size.
            Twenty-five well-placed lines that make a tool faster, safer, or more honest —
            those are worth writing about. A typo fix lives in a monthly recap, not its own page.
          </p>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .c-hero {
    padding: 4rem 0 2.5rem;
  }

  .c-hero-wrap {
    max-width: 44rem;
    margin: 0 auto;
  }

  .c-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
    opacity: 0.85;
  }

  .c-hero h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .c-lede {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .c-lede strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .c-hint, .c-backlog-lede, .c-backlog-note {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    opacity: 0.85;
  }

  .c-hint code, .c-backlog-lede code {
    color: var(--color-accent);
    background: rgba(56, 189, 248, 0.06);
    padding: 0.05rem 0.35rem;
    border-radius: 3px;
    font-size: 0.88em;
  }

  .c-list-section { padding: 2rem 0 3rem; }

  .c-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 46rem;
    margin: 0 auto;
  }

  .c-card {
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: 6px;
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.03), transparent 60%);
  }

  .c-card-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .c-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .c-pr-number {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .c-pr-number:hover {
    color: var(--color-accent-hover);
  }

  .c-sep {
    color: var(--color-text-muted);
    opacity: 0.4;
  }

  .c-date {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    opacity: 0.8;
  }

  .c-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    text-transform: uppercase;
  }

  .c-badge-first {
    background: rgba(56, 189, 248, 0.15);
    color: var(--color-accent);
    border: 1px solid rgba(56, 189, 248, 0.3);
  }

  .c-status {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.15rem 0.55rem;
    border-radius: 3px;
    font-weight: 600;
  }

  .c-status-merged {
    background: rgba(34, 197, 94, 0.12);
    color: #4ade80;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .c-status-open {
    background: rgba(56, 189, 248, 0.12);
    color: var(--color-accent);
    border: 1px solid rgba(56, 189, 248, 0.3);
  }

  .c-status-closed {
    background: rgba(148, 163, 184, 0.12);
    color: #94a3b8;
    border: 1px solid rgba(148, 163, 184, 0.3);
  }

  .c-project {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.4rem;
    letter-spacing: 0.02em;
  }

  .c-title {
    font-size: 1.1rem;
    color: var(--color-text);
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.9rem;
  }

  .c-insight {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    padding: 0.75rem 1rem;
    background: rgba(15, 23, 42, 0.4);
    border-radius: 4px;
    border-left: 2px solid rgba(56, 189, 248, 0.3);
    margin-bottom: 1rem;
  }

  .c-insight-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-accent);
    letter-spacing: 0.08em;
    margin-bottom: 0.25rem;
    opacity: 0.85;
  }

  .c-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .c-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    background: rgba(56, 189, 248, 0.05);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    border: 1px solid rgba(56, 189, 248, 0.1);
  }

  .c-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .c-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
